        }, 
        /**
         * Form 하위 component 전체 조회
         * @param  : {nexacro.Form} [formObj  ] 대상 form
         * @param  : {String}       [targetKey] 검색 key
         * @return : {Object}
         *           - {nexacro.Component[]} [components] : 하위   component 배열
         *           - {nexacro.Dataset  []} [lDatasets ] : 하위   dataset   배열
         *           - {nexacro.Dataset  []} [gDatasets ] : global dataset   배열
         *           - {nexacro.BindItem []} [binds     ] : 하위   binding   배열
         *           - {nexacro.Form     []} [urlForms  ] : 하위   form      배열 (url 호출 form에 한함)
         *           - {Object           []} [targets   ] : 검색결과(검색 key 존재 시)
         *             - {String} [rootForm  ] : 부모 form
         *             - {Object} [target    ] : 검색결과 object
         */
        getAll : function(formObj, targetKey)
        {
            if(formObj==null || !(formObj instanceof nexacro.Form))
            {
                let nullObj = {};
                nullObj.components  = [];
                nullObj.lDatasets   = [];
                nullObj.gDatasets   = [];
                nullObj.binds       = [];
                nullObj.urlForms    = [];
                return nullObj;
            }
            
            let application = nexacro.getApplication();
            let appObjs     = application.all;
            let gDatasetArr = [];
            let formQueue   = [];
            let compArr     = [];
            let lDatasetArr = [];
            let bindArr     = [];
            let formArr     = [];
            let targetArr   = [];
            let targetKeys  = [];
            
            if(targetKey)
            {
                targetKeys = targetKey.split(".");
            }
        
            // global dataset
            for(let i=0;i<appObjs.length;i++)
            {
                let appObjId = appObjs._idArray[i];
                let appObj   = application[appObjId];
                if(appObj && (appObj instanceof nexacro.Dataset))
                {
                    gDatasetArr.push(appObj);
                }
            }
            
            // Form
            formQueue.push(formObj);
            formArr.push  (formObj);
            
            //////////////////////////////////////////////////////////////////////////
            // component loop START
            //
            
            // components sort by taborder function
            let lfnSortComp = function(comps)
                              {
                                  if(!comps){return [];}
                                  if(!comps.length){return [];}
                                  let compsObjTmp = {};
                                  let seq = 0;
                                  for(let i=0;i<comps.length;i++)
                                  {
                                      let comp     = comps[i];
                                      let tabOrder = parseInt(comp.taborder);
                                      if(isNaN(tabOrder))
                                      {
                                          tabOrder = "NaN";
                                      }
                                      else if(tabOrder < 0)
                                      {
                                          tabOrder = "-1";
                                      }
                                      else if(tabOrder>seq)
                                      {
                                          seq = tabOrder;
                                      }
                                      if(typeof compsObjTmp[tabOrder]=="undefined")
                                      {
                                          compsObjTmp[tabOrder] = [];
                                      }
                                      compsObjTmp[tabOrder].push(comp);
                                  }
                                  
                                  let compsArrTmp = [];
                                  for(let i=0;i<=seq;i++)
                                  {
                                      if(typeof compsObjTmp[i]=="object" && (compsObjTmp[i] instanceof Array))
                                      {
                                          let compsTmp = compsObjTmp[i];
                                          for(let x=0;x<compsTmp.length;x++)
                                          {
                                              let compTmp = compsTmp[x];
                                              compsArrTmp.push(compTmp);
                                          }
                                      }
                                  }
                                  if(typeof compsObjTmp["-1"]=="object" && (compsObjTmp["-1"] instanceof Array))
                                  {
                                      let compsTmp = compsObjTmp["-1"];
                                      for(let x=0;x<compsTmp.length;x++)
                                      {
                                          let compTmp = compsTmp[x];
                                          compsArrTmp.push(compTmp);
                                      }
                                  }
                                  if(typeof compsObjTmp["NaN"]=="object" && (compsObjTmp["NaN"] instanceof Array))
                                  {
                                      let compsTmp = compsObjTmp["NaN"];
                                      for(let x=0;x<compsTmp.length;x++)
                                      {
                                          let compTmp = compsTmp[x];
                                          compsArrTmp.push(compTmp);
                                      }
                                  }
                                  return compsArrTmp;
                              };
            let components = lfnSortComp(formObj.components);
            while(components.length)
            {
                let component = components.shift();
                compArr.push(component);
                // Frame, Div
                if(component.form && (component.form instanceof nexacro.Form))
                {
                    formQueue.push(component.form);
                    if(component.url || component.formurl)
                    {
                        formArr.push(component.form);
                    }
                    let innerComponents = lfnSortComp(component.form.components);
                    components = innerComponents.concat(components);
                }
                // Tab
                else if(component instanceof nexacro.Tab)
                {
                    let tabPages = component.tabpages;
                    if(tabPages && tabPages.length)
                    {
                        // tabpage loop
                        let tabComponents = [];
                        for(let x=0;x<tabPages.length;x++)
                        {
                            let tabPage = tabPages[x];
                            let tabForm = tabPage.form;
                            if(tabForm && (tabForm instanceof nexacro.Form))
                            {
                                formQueue.push(tabForm);
                                if(tabPage.url || tabPage.formurl)
                                {
                                    formArr.push(tabForm);
                                }
                                let tabInnerComponents = lfnSortComp(tabForm.components);
                                tabComponents = tabComponents.concat(tabInnerComponents);
                            }
                        }
                        components = tabComponents.concat(components);
                    }
                }
            }
            //
            // component loop END
            //////////////////////////////////////////////////////////////////////////
            
            // Queue
            while(formQueue.length)
            {
                let form = formQueue.shift();
                if(targetKey)
                {
                    let target = form[targetKey];
                    if(target)
                    {
                        targetArr.push({rootForm:form,target:target});
                    }
                    if(targetKeys.length)
                    {
                        let targetTmp = form[targetKeys[0]];
                        if(targetTmp)
                        {
                            let isTarget  = true;
                            for(let i=1;i<targetKeys.length;i++)
                            {
                                let targetKeyTmp = targetKeys[i];
                                targetTmp = targetTmp[targetKeyTmp];
                                if(targetTmp)
                                {
                                    continue;
                                }
                                isTarget = false;
                            }
                            if(isTarget)
                            {
                                targetArr.push({rootForm:form,target:targetTmp});
                            }
                        }
                    }
                }
                
                let objects = form.objects;
                if(objects && objects.length)
                {
                    // objects loop
                    for(let i=0;i<objects.length;i++)
                    {
                        let object = objects[i];
                        if(object instanceof nexacro.Dataset)
                        {
                            lDatasetArr.push(object);
                        }
                    }
                }
                
                let binds = form.binds;
                if(binds && binds.length)
                {
                    // bind loop
                    for(let i=0;i<binds.length;i++)
                    {
                        let bind = binds[i];
                        bindArr.push(bind);
                    }
                }
            }
            
            let returnObj = {};
            returnObj.components  = compArr    ;
            returnObj.lDatasets   = lDatasetArr;
            returnObj.gDatasets   = gDatasetArr;
            returnObj.binds       = bindArr    ;
            returnObj.urlForms    = formArr    ;
            if(targetKey)
            {
                returnObj.targets = targetArr  ;
            }
            
            return returnObj;
        },
        /**
         * 로그 공통
         * @param {All   } [target]
         * @param {Number} [stack ] : trace stack (default:2)
         * @return N/A
         * @example
         * Drps.Core.trace(this);
         * Drps.Core.trace("aaa");
         * Drps.Core.trace(123);
         * Drps.Core.trace(this.Grd_menu00);
         * Drps.Core.trace(this.ds_menu00);
         */
        trace : function( target, stack )
        {
            let maxSpace = 10000;
            let space    = 0;
            let buff     = 30;
            let maxStack = 0;
            if(typeof stack=="number" && stack > 0)
            {
                maxStack = stack;
            }
            
            let tracelog = nexacro.getApplication().__traceLog;
            
            if(tracelog==null)
            {
                nexacro.getApplication().__traceLog = [];
                tracelog = nexacro.getApplication().__traceLog;
            }
            
            let traceSeq  = 0;
            let lastTrace = tracelog[tracelog.length-1];
            if(typeof lastTrace=="object")
            {
                traceSeq = lastTrace.seq + 1;
            }
            if(traceSeq>buff+2)
            {
                traceSeq = 0;
            }
            let traceObj = {seq:traceSeq, trace:target};
            tracelog.push(traceObj);
            
            if(typeof target=="object" && maxStack!==1)
            {
                traceObj.traceSub = [];
                let traceSub      = traceObj.traceSub;
                let traceCntArr   = [];
                for(let key in target)
                {
                    traceCntArr.push(target[key]);
                    space++;
                }
                let maxStackTmp = 2;
                while(traceCntArr.length && space < maxSpace && maxStack!==2)
                {
                    let traceCntTmp = [];
                    while(traceCntArr.length)
                    {
                        let traceTmp = traceCntArr.shift();
                        if(typeof traceTmp=="object")
                        {
                            for(let key in traceTmp)
                            {
                                traceCntTmp.push(traceTmp[key]);
                                space++;
                            }
                        }
                    }
                    traceCntArr = traceCntTmp;
                    maxStackTmp++;
                    if(maxStack > 0 && maxStackTmp >= maxStack)
                    {
                        break;
                    }
                }
                maxStack = maxStackTmp;
                let stack    = [];
                let stackArr = [];
                for(let key in target)
                {
                    stackArr.push({key:key,value:target[key]});
                }
                stack.push(stackArr);
                
                while(stack.length)
                {
                    let levl     = stack.length+1;
                    let stackArr = stack.pop();
                    while(stackArr.length)
                    {
                        let stackTrace    = stackArr.shift();
                        let stackTraceObj = stackTrace.value;
                        let stackTraceStr = stackTraceObj;
                        if(stackTraceObj==null)
                        {
                            stackTraceStr = "";
                        }
                        else if(typeof stackTraceObj=="function")
                        {
                            stackTraceStr = stackTraceObj.toString();
                        }
                        else if(typeof stackTraceObj.toString=="function")
                        {
                            try
							{
							    stackTraceStr = stackTraceObj.toString();
							}
							catch(e)
							{
							    stackTraceStr = "undefined";
							}
                        }
                        else if(typeof stackTraceObj=="object")
                        {
                            stackTraceStr = String.valueOf(stackTraceObj);
                        }
                        
                        if(typeof stackTraceStr=="string")
                        {
                            stackTraceStr = stackTraceStr.replace(/<\/(col|row)>/gi,"&lt;/$1&gt;");
                        }
                        
                        traceSub.push({levl:levl,key:stackTrace.key,value:stackTraceStr});
                        
                        if(levl>=maxStack)
                        {
                            continue;
                        }
                        else if(typeof stackTraceObj=="object")
                        {
                            stack.push(stackArr);
                            let stackArrTmp = [];
                            for(let key in stackTraceObj)
                            {
                                stackArrTmp.push({key:key,value:stackTraceObj[key]});
                            }
                            stack.push(stackArrTmp);
                            break;
                        }
                    }
                }
                
            }
            
            if(tracelog.length>buff)
            {
                tracelog.shift();
            }
            
            trace(target);
        },
        /**
         * 설  명 : 인자를 넘겨줄 경우에 넘겨주는 규칙대로 인자/값을 설정
         * Params : p_name - 설정할 파리미터명
                    p_value - 설정할 값
