        /**
         * 현재 선택된 권한코드 조회
         *   1순위: Form_Top 의 Div_title00.form.cmbAuth.value (사용자가 콤보로 변경한 권한)
         *   2순위: gdsAuth 의 현재 rowposition 행 authCd
         *   3순위: gdsLoginInfo 의 authCd 후보 컬럼 (최초 로그인 권한)
         * @return {String} 권한코드 (없으면 "")
         * @example
         *      let authCd = Drps.Core.getCurrentAuthCd();
         *      if(authCd == "DRPS_ROLE_00007"){ ... }
         * @memberOf Drps.Core
         */
        getCurrentAuthCd : function()
        {
            let app = nexacro.getApplication();
            if(!app){ return ""; }

            // 1순위: Form_Top 의 cmbAuth.value
            try {
                let gvTop   = app.gvTop;
                let topForm = gvTop ? (typeof gvTop.getForm == "function" ? gvTop.getForm() : gvTop) : null;
                if(topForm && topForm.Div_title00 && topForm.Div_title00.form && topForm.Div_title00.form.cmbAuth)
                {
                    let cmbVal = topForm.Div_title00.form.cmbAuth.value;
                    if(cmbVal != undefined && cmbVal != null && cmbVal != "")
                    {
                        return cmbVal;
                    }
                }
            } catch(ex) {
                trace("[Drps.Core.getCurrentAuthCd] gvTop 접근 예외: " + ex.message);
            }

            // 2순위: gdsAuth (rowposition 또는 first row)
            if(app.gdsAuth && app.gdsAuth.getRowCount() > 0)
            {
                let rowPos = app.gdsAuth.rowposition;
                if(rowPos < 0){ rowPos = 0; }
                let v2 = app.gdsAuth.getColumn(rowPos, "authCd");
                if(v2 != undefined && v2 != null && v2 != "")
                {
                    return v2;
                }
            }

            // 3순위: gdsLoginInfo 후보 컬럼
            if(app.gdsLoginInfo && app.gdsLoginInfo.getRowCount() > 0)
            {
                let ds = app.gdsLoginInfo;
                let candidates = ["authCd", "auth_grp_id", "auth_cd", "authGrpId", "role_id"];
                for(let i=0; i<candidates.length; i++)
                {
                    let v = ds.getColumn(0, candidates[i]);
                    if(v != undefined && v != null && v != "")
                    {
                        return v;
                    }
                }
            }

            return "";
        },
        /**
         * form 종료전 체크 공통
         * @param  {nexacro.Form} [formObj] 종료대상 form
         * @return {Boolean     } 종료가능여부(true:가능,false:불가능)
         */
        formCloseCheck : function(formObj)
        {
			let pageId = this.getIdOfMainForm(formObj);
            try{
                let ret = true;
                if(pageId)
                {
                    ret = formObj.fnCloseCheck("onBeforeCloseForm");
                }
                else if(formObj.onBeforeCloseForm && typeof formObj.onBeforeCloseForm=="function")
                {
                    ret = formObj.onBeforeCloseForm();
                }
                
                if(nexacro.getApplication().__closeCheck)
                {
                    return "datasetUpdated";
                }
                
                if(ret===false)
                {
                    return false;
                }
                else
                {
                    return true;
                }
            }catch(e){
                let stackArr   = ["////////////////////////////////////////"];
                    stackArr.push("// 화면담당자 프로그램 수정 요망");
                    stackArr.push("// function : onBeforeCloseForm");
                    stackArr.push("// " + e.message);
                    stackArr.push("////////////////////////////////////////");
                for(let i in e.stack)
                {
                    stackArr.push(e.stack[i]);
                }
                this.trace("\n" + stackArr.join("\n"));
                Drps.Util.alertBox(stackArr.join("\n"),null,"onBeforeCloseForm ERROR", "ERR");
                throw e;
            }finally{
                delete nexacro.getApplication().__closeCheck;
            }
        },
        /**
         * 화면 open
         * @param {Object      } [options] 호출 option
         *                        - {String } [formId       ] : 호출 form id(필수)
         *                        - {String } [url          ] : 호출 form url
         *                        - {String } [title        ] : 호출 form titleText
         *                        - {Object } [paramContents] : 전송 parameter
         *                        - {Boolean} [reload       ] : 화면 reload 여부(true:reload, false:reload 안함)(default:true)
         * @return N/A
         * @example
         * Drps.Core.openForm({formId : "M00222"})
         * Drps.Core.openForm({
         *                    formId : "userOpen"
         *                   ,url    : "XX::XX1010M01.xfdl"
         *                   ,title  : "테스트화면"
         *                   })
         * Drps.Core.openForm({
         *                    formId        : "userOpen"
         *                   ,url           : "XX::XX1010M01.xfdl"
         *                   ,title         : "테스트화면"
         *                   ,paramContents : {aaa:"bbb"}
         *                   })
         * Drps.Core.openForm({
         *                    formId        : "userOpen"
         *                   ,url           : "XX::XX1010M01.xfdl"
         *                   ,title         : "테스트화면"
         *                   ,paramContents : {aaa:"bbb"}
         *                   ,reload        : false
         *                   })
         */
        openForm : function(options)
        {
            let ffobj = Drps.Util.ffobj;
            options = options||{};
            options.formId        = options.formId||"";
            options.url           = options.url   ||"";
            options.title         = options.title ||"";
            options.paramContents = options.paramContents||{};
            options.reload        = options.reload;
            if(options.reload!==false)
            {
                options.reload=true;
            }
            
            if(!options.formId)
            {
                this.trace("formId 미존재");
                return;
            }
            
            options.paramContents._openerId = ffobj._openerId||ffobj._pageId;
            
            if(this.getIdOfWorkForm(Drps.Util.ffobj))
            {
                nexacro.getApplication().gfnOpen(options.formId, options.url, options.title, options.paramContents, options.reload);
            }
            else
            {
                Drps.Util.openPopup(
                                   options.formId
                                  ,options.url
                                  ,{_params:options.paramContents}
                                  ,null
                                  ,{
                                    width    :1350
                                   ,height   :840
                                   }
                                  );
            }
            
        },

        /**
         * status바 메세지 세팅
         * @param {String} [strMsg] - 메세지 내용
         * @memberOf Message
         */
        setStatus : function(strMsg)
        {
            let gdsProcCntn = nexacro.getApplication().gdsProcCntn;
            let maxRow = gdsProcCntn.getConstColumn("maxRow");
            while(gdsProcCntn.getRowCount()>=maxRow)
            {
                gdsProcCntn.deleteRow(0);
            }
            let currow = gdsProcCntn.addRow(0);
            gdsProcCntn.setColumn(currow,"procCntn",strMsg);
            gdsProcCntn.applyChange();
            gdsProcCntn.set_rowposition(currow);
        },
        
        /**
        * @class 사용자별 화면내 버튼, 개인정보 권한 처리
        * @param {Object} 호출 화면 객체
        * @param {Array} JSON을 담고 있는 배열
        *       - {button}  [button        ] 권한을 설정할 버튼 객체
        *       - {String}  [auth          ] 부여할 권한
        *               "IQRY"   - 조회권한
        *               "EXCEL"  - 엑셀 다운로드 권한
        *               "OUTPUT" - 출력권한(보고서)
        *               "PROC"   - 처리권한
        * @return
        * @example 
        *       Drps.Core.setUserAuth(this,[
                      {button: this.divHeader.form.btnClear  , auth: "IQRY"  }
                    , {button: this.divSearch.form.btnSearch , auth: "IQRY"  }
                    , {button: this.btnAdd                   , auth: "PROC"  }
                    , {button: this.btnAdd01                 , auth: "PROC"  }
                    , {button: this.btnDel                   , auth: "PROC"  }
                    , {button: this.btnDel01                 , auth: "PROC"  }
                    , {button: this.btnSave                  , auth: "PROC"  }
                    , {button: this.btnExcel                 , auth: "EXCEL" }
                    , {button: this.btnExcel01               , auth: "EXCEL" }
                ]);
        * @memberOf Drps.Core
        */
        setUserAuth : function(objForm, arrJson)
        {
            let strMenuCd = objForm._openerId;
            let objGDs = nexacro.getApplication().gdsMenu;
            let nRow = objGDs.findRow("menuCd", strMenuCd);
            
            let arrAuth = [];
            
            // 권한이 없는 경우 비활성화 대상에 포함
            if(objGDs.getColumn(nRow, "iqryAuthYn") == "N")
            {
                arrAuth.push("IQRY");
            }
            
            if(objGDs.getColumn(nRow, "excelAuthYn") == "N")
            {
                arrAuth.push("EXCEL");
            }
            
            if(objGDs.getColumn(nRow, "outptAuthYn") == "N")
            {
                arrAuth.push("OUTPUT");
            }
            
            if(objGDs.getColumn(nRow, "procAuthYn") == "N")
            {
                arrAuth.push("PROC");
            }
            
            // 권한없는 버튼에 대해 마스킹처리
            for(let i=0;i<arrJson.length;i++)
            {
                if(arrAuth.indexOf(arrJson[i].auth) > -1)
                {
                    Drps.Core._setAuthCover(arrJson[i].button);
                }
            }
            
            // 그리드 
            let arrGrid = Drps.Core.getAll(objForm).components.filter(function(val){
                                return Drps.Util.typeOf(val) == "Grid"
                          });
            
            // 개인정보권한이 있다면 그리드 마스킹은 그대로 두고 툴팁에 마스킹을 해제하여 보여줌
            if(objGDs.getColumn(nRow, "indvInfoAuthYn") == "Y")
            {
                for(let i=0;i<arrGrid.length;i++)
                {
                    let objGrid = arrGrid[i];
                    for(var nCell = 0; nCell < objGrid.getCellCount("Body"); nCell++)
                    {
                        let strDisplyType = objGrid.getCellProperty("Body", nCell, "displaytype");
                        let strText = objGrid.getCellProperty("Body", nCell, "expr")||"";
                        
                        // 툴팁에 마스킹을 해제하여 보여줌
                        if(strDisplyType == "mask" || (strText && strText.indexOf("masking") > -1))
                        {
                            // 개인정보 마스킹이 있는경우에만 마스킹해제하여 툴팁에 넣어둠
                            if(objGrid.getCellProperty("Body", nCell, "maskeditformat").match(/{|}/))
                            {
                                objGrid.setCellProperty("Body", nCell, "tooltiptext", objGrid.getCellProperty("Body", nCell, "text"));
                            }
                            // 함수를 이용한 한글마스킹일때 마스킹을 해제하여 보여줌
                            else if(strText.match(/\'.*\'|\".*\"/))
                            {
                                objGrid.setCellProperty("Body", nCell, "tooltiptext", objGrid.getCellProperty("Body", nCell, "text"));
                            }
                        }
                        /*if(strDisplyType == "mask")
                        {
                            let strFormat = objGrid.getCellProperty("Body", nCell, "maskeditformat");
                            
                            // 숫자형 포멧이면 마스킹 문자인 중괄호를 제거
                            strFormat = strFormat.replace(/{|}/gi, "");
                            objGrid.setCellProperty("Body", nCell, "maskeditformat", strFormat);
                        }
                        // 문자열을 마스킹 한 경우 정규식을 초기화
                        else if(strText && strText.indexOf("masking") > -1)
                        {
                            strText = strText.replace(/\'.*\'|\".*\"/gi, '""');
                            objGrid.setCellProperty("Body", nCell, "expr", strText);
                        }*/
                    }
                }
                
                // 마스크에디트 
                let arrMask = Drps.Core.getAll(objForm).components.filter(function(val){
                    return Drps.Util.typeOf(val) == "MaskEdit"
                });
                
                for(let i=0;i<arrMask.length;i++)
                {
                    let objMask = arrMask[i];
                    // 마스킹 문자인 중괄호를 제거
                    objMask.set_format(objMask.format.replace(/{|}/gi, ""));
                }
                
            }
            
            
        },
        
        /**
        * @class 사용자별 화면 내 정보 반환
        * @param {Object} 호출 화면 객체
        * @param {String} 키값 - 부여할 권한 또는 gdsMenu의 vo명 null 값이면 현재 화면의 gdsMenu값을 Json으로 반환
        * @return Object
        * @example 
        *       Drps.Core.getMenuInfo(this,"iqryAuthYn");
        *       Drps.Core.getMenuInfo(this,"excelAuthYn");
        *       Drps.Core.getMenuInfo(this,"outptAuthYn");
        *       Drps.Core.getMenuInfo(this,"procAuthYn");
        *       Drps.Core.getMenuInfo(this,"indvInfoAuthYn");
        * @memberOf Drps.Core
        */
        getMenuInfo : function(objForm, strKey)
        {
            let strMenuCd = objForm._openerId;
            let objGDs = nexacro.getApplication().gdsMenu;
            let nRow = objGDs.findRow("menuCd", strMenuCd);
            
            if(strKey)
            {
                return objGDs.getColumn(nRow, strKey);
            }
            //  현재 메뉴의 모든 정보를 반환
            else
            {
                let objMenuInfo = {};
                for(let i = 0; i < objGDs.colcount; i++)
                {
                    let strColId = objGDs.getColID(i);
                    let objColVl = objGDs.getColumn(nRow, strColId);
                    if ( typeof objColVl == "object" ) {
                        objMenuInfo[strColId] = ( objColVl || "" ).toString();
                    } else {
                        // primitive type
                        objMenuInfo[strColId] = objColVl;
                    }
                }
                return objMenuInfo;
            }
        },
        
        /**
         * error 표시
         * @param {String} [errMsg] - error message
         * error trace 처리
         */
        showError : function(errMsg)
        {
            try{
                throw new Error(errMsg);
            }catch(e){
                let errStr  = "\n//////////////////////////////////////////////////////////////\n";
                    errStr +=   "// Script Error\n";
                    errStr +=   "// " + e.toString() + "\n";
                    errStr +=   "//////////////////////////////////////////////////////////////\n";
                    errStr +=   e.stack.join("\n");
                    
                Drps.Util.alertBox(errStr,null, "에러발생", "ERR");
                throw e;
                
            }
        }
    });
