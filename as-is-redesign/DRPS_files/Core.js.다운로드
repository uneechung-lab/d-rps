        },
        /**
         * Calendar Init
         * @param {nexacro.Calendar} [calendarObj] : 대상 calendar
         * @return N/A
         * dateFormat yyyy-MM일 시
         * - value 6자리 slice 처리
         * - 월팝업으로 변경(미구현)
         */
        initCalendar : function(calendarObj)
        {
            let formObj = calendarObj.parent;
            if(formObj instanceof nexacro.Form)
            {
                // formObj = formObj;
            }
            else if(formObj.form && (formObj.form instanceof nexacro.Form))
            {
                formObj = formObj.form;
            }
            else
            {
                return;
            }
            
            let dateformat = calendarObj.dateformat;
            if(dateformat=="yyyy-MM")
            {
                let maskObj = calendarObj._masktypeobj;
                if(maskObj && typeof maskObj.__changeNormalizeValueTmp=="undefined")
                {
                    maskObj.__changeNormalizeValueTmp = maskObj.changeNormalizeValue;
                    maskObj.changeNormalizeValue = function(v)
                                                   {
                                                       v = maskObj.__changeNormalizeValueTmp(v)||"";
                                                       return v.substring(0,6);
                                                   };
                }
                
                if(typeof calendarObj.__onValueChangeTmp=="undefined")
                {
                    calendarObj.__onValueChangeTmp = calendarObj._on_value_change;
                    calendarObj._on_value_change = function (prevalue, postvalue) {
                        postvalue = postvalue.substring(0,6);
                        this.__onValueChangeTmp(prevalue, postvalue);
                    };
                }
                if(typeof calendarObj.__convertValueTypeTmp=="undefined")
                {
                    calendarObj.__convertValueTypeTmp = calendarObj._convertValueType;
                    calendarObj._convertValueType = function (v, dateobj, bapplyrule)
                    {
                        let ret = calendarObj.__convertValueTypeTmp(v, dateobj, bapplyrule);
                        if(typeof ret=="string")
                        {
                            return ret.substring(0,6);
                        }
                        else
                        {
                            return ret;
                        }
                    }
                }
                
                calendarObj._monthPickerTmp = new PopupDiv();
                let calendarId    = calendarObj.id;
                let monthPickerId = calendarObj.id+"_month_";
                calendarObj._monthPickerTmp.init(
                                                 monthPickerId
                                                ,0
                                                ,0
                                                ,0
                                                ,0
                                                );
                if(calendarObj._monthPicker)
                {
                    formObj.removeChild(calendarObj._monthPicker.id);
                    calendarObj._monthPicker.destroy();
                }
                calendarObj._monthPicker = calendarObj._monthPickerTmp;
                delete calendarObj._monthPickerTmp;
                formObj.addChild(monthPickerId,calendarObj._monthPicker);
                calendarObj._monthPicker.show();
                calendarObj._monthPicker.set_async(false);
                calendarObj._monthPicker.set_url("Comm::monthcalendar_inner.xfdl");
                let monthPickerForm = calendarObj._monthPicker.form;
                monthPickerForm.fnSetCurrYear ();
                monthPickerForm.fnSetCurrMonth();
                calendarObj._monthPicker.resize(155,160);
                if(typeof formObj["__" + calendarObj.id+"MonthPickerCallback__"]=="undefined")
                {
                    formObj["__" + calendarObj.id+"MonthPickerCallback__"] = function(pickerId, retVal)
                                                                             {
                                                                                 if(retVal)
                                                                                 {
                                                                                     let oldValue = calendarObj.value;
                                                                                     if(oldValue!==retVal)
                                                                                     {
                                                                                         calendarObj._on_value_change(oldValue,retVal);
                                                                                     }
                                                                                     calendarObj._changeStatus("mouseover", false);
                                                                                     calendarObj.calendaredit._changeStatus("mouseover", false);
                                                                                     calendarObj.dropbutton._changeStatus("mouseover", false);
                                                                                 }
                                                                             };
                }
                calendarObj._onDropDownFuncTmp = function(obj,e)
                                                 {
                                                     if(obj._monthPicker)
                                                     {
                                                         let monthForm = obj._monthPicker.form;

                                                         obj._monthPicker.trackPopupByComponent(obj,0,obj.getOffsetHeight(),null,null,"__" + calendarObj.id+"MonthPickerCallback__");
                                                         if(obj.calendaredit && obj.calendaredit.value)
                                                         {
                                                             let strYear = obj.calendaredit.value.substring(0,4);
                                                             let strMonth = obj.calendaredit.value.substring(4,6);
                                                             monthForm.fnInitDate(strYear,strMonth);
                                                         }
                                                         else if(obj.value)
                                                         {
                                                             let strYear = obj.calendaredit.value.substring(0,4);
                                                             let strMonth = obj.value.substring(4,6);
                                                             monthForm.fnInitDate(strYear,strMonth);
                                                         }
                                                     }
                                                     return false;
                                                 };
                if(calendarObj._onDropDownFunc && typeof calendarObj._onDropDownFunc==="function")
                {
                    calendarObj.removeEventHandler("ondropdown",calendarObj._onDropDownFunc,calendarObj);
                }
                calendarObj._onDropDownFunc = calendarObj._onDropDownFuncTmp;
                calendarObj.addEventHandler("ondropdown",calendarObj._onDropDownFunc,calendarObj);
                
                if(calendarObj.value && calendarObj.value.length > 6)
                {
                    calendarObj.set_value(calendarObj.value);
                }
            }
            else
            {   let maskObj = calendarObj._masktypeobj;
                if(maskObj && typeof maskObj.__changeNormalizeValueTmp=="function")
                {
                    maskObj.changeNormalizeValue = maskObj.__changeNormalizeValueTmp;
                    delete maskObj.__changeNormalizeValueTmp;
                }
                if(typeof calendarObj.__onValueChangeTmp=="function")
                {
                    calendarObj._on_value_change = calendarObj.__onValueChangeTmp;
                    delete calendarObj.__onValueChangeTmp;
                }
                
                if(typeof calendarObj.__convertValueTypeTmp=="function")
                {
                    calendarObj._convertValueType = calendarObj.__convertValueTypeTmp;
                    delete calendarObj.__convertValueTypeTmp;
                }
                
                if(typeof formObj["__" + calendarObj.id+"MonthPickerCallback__"]=="function")
                {
                    delete formObj["__" + calendarObj.id+"MonthPickerCallback__"];
                }
                
                if(calendarObj._monthPicker && (calendarObj._monthPicker instanceof nexacro.PopupDiv))
                {
                    formObj.removeChild(calendarObj._monthPicker.id);
                    calendarObj._monthPicker.destroy();
                    delete calendarObj._monthPicker;
                }
                
                if(calendarObj._onDropDownFunc && typeof calendarObj._onDropDownFunc==="function")
                {
                    calendarObj.removeEventHandler("ondropdown",calendarObj._onDropDownFunc,calendarObj);
                    delete calendarObj._onDropDownFunc;
                }
                
                if(calendarObj.value && calendarObj.value.length == 6)
                {
                    calendarObj.set_value(calendarObj.value+"01");
                }
            }
        },
        /**
         * WebBrowser Init
         * @param {nexacro.WebBrowser} [webBrowserObj] : 대상 WebBrowser
         * @return N/A
         * onload flag 부여
         */
        initWebBrowser : function(webBrowserObj)
        {
            webBrowserObj._loadEventFuncTmp = function(obj, e)
                                              {
                                                  obj._isLoaded = true;
                                              };
            if(typeof webBrowserObj._loadEventFunc=="function")
            {
                webBrowserObj.removeEventHandler("onloadcompleted",webBrowserObj._loadEventFunc,webBrowserObj);
            }
            webBrowserObj._loadEventFunc = webBrowserObj._loadEventFuncTmp;
            webBrowserObj.addEventHandler("onloadcompleted",webBrowserObj._loadEventFunc,webBrowserObj);
            delete webBrowserObj._loadEventFuncTmp;
        },
        /**
         * Spin Init
         * @param {nexacro.Spin} [spinObj] : 대상 Spin
         * @return N/A
         * 하위 edit onchange 시 enter key event 유도
         */
        initSpin : function(spinObj)
        {
            if(spinObj==null){return;}
            if(!(spinObj instanceof nexacro.Spin)){return;}
            let spinEdit = spinObj.spinedit;
            if(spinEdit && (spinEdit instanceof nexacro.MaskEdit))
            {
                if(typeof spinEdit.__onValueChangeTmp != "function")
                {
                    spinEdit.__onValueChangeTmp = spinEdit._on_value_change;
                    spinEdit._on_value_change = function(pretext, prevalue, posttext, postvalue)
                                                {
                                                    let ret = spinEdit.__onValueChangeTmp(pretext, prevalue, posttext, postvalue);
                                                    if(ret===true)
                                                    {
                                                        if(this.parent && (this.parent instanceof nexacro.Spin))
                                                        {
                                                            let parentSpin = this.parent;
                                                            if(typeof parentSpin._on_edit_onkeydown=="function")
                                                            {
                                                                parentSpin.set_value(postvalue);
                                                                let e={keycode:nexacro.Event.KEY_ENTER};
                                                                parentSpin._on_edit_onkeydown(parentSpin,e);
                                                            }
                                                        }
                                                    }
                                                    return ret;
                                                };
                }
            }
            
        },
        /**
         * Combo Init
         * @param {nexacro.Combo} [comboObj] : 대상 Combo
         * @return N/A
         * innerdataset 보이지 않는 행도 display 가능하도록 변경
         */
        initCombo : function(comboObj)
        {
            if(comboObj==null){return;}
            if(!(comboObj instanceof nexacro.Combo)){return;}
            comboObj.__setTextTmp = comboObj._setText;
            comboObj._setText = function(v)
                                {
                                    let inDs      = this.getInnerDataset();
                                    if(Drps.Util.isNull(v) && inDs && (inDs instanceof nexacro.Dataset))
                                    {
                                        let codeColNm = this.codecolumn;
                                        let dataColNm = this.datacolumn;
                                        let code      = this.value;
                                        let targetRow = inDs.findRowNF(codeColNm,code,0);
                                        if(targetRow > -1)
                                        {
                                            v = inDs.getColumnNF(targetRow, dataColNm);
                                        }
                                    }
                                    this.__setTextTmp(v);
                                };
        },
        /**
         * 업무화면 검증
         * @param  {nexacro.Form} [formObj] : 검증대상 form
         * @return {String} 업무화면 form 일 시 업무화면 ID
         *                  업무화면 form 아닐 시 null
         * 업무화면여부
         * - 업무 Form depth : frameSet > childFrame > form > Div > 업무 Form
         */
        getIdOfWorkForm : function(formObj)
        {
            if(!formObj){return null;}
            if(formObj instanceof nexacro.TitleBarControl){return null;}
            if(formObj instanceof nexacro.Form)
            {
                if(formObj.name=="form"){return null;}
                let mainFrame = nexacro.getApplication().gvMain;
                let parentObj = formObj.parent;
                if(parentObj && (parentObj instanceof nexacro.Div))
                {
                    let gParentObj = parentObj.parent;
                    if(gParentObj && (gParentObj instanceof nexacro.Form))
                    {
                        let ggParentObj = gParentObj.parent;
                        if(ggParentObj && (ggParentObj instanceof nexacro.ChildFrame))
                        {
                            if(ggParentObj.parent===mainFrame)
                            {
                                return ggParentObj.id;
                            }
                        }
                    }
                }
            }
            return null;
        },
        /**
         * 업무화면 검증
         * @param  {nexacro.Form} [formObj] : 검증대상 form
         * @return {Boolean} 업무화면 여부
         * 업무화면여부
         * - 업무 Form depth : frameSet > childFrame > form > Div > 업무 Form
         */
        isWorkForm : function(formObj)
        {
            if(!formObj){return false;}
            if(formObj instanceof nexacro.TitleBarControl){return false;}
            if(formObj instanceof nexacro.Form)
            {
                let mainFrame = nexacro.getApplication().gvMain;
                let parentObj = formObj.parent;
                if(parentObj && (parentObj instanceof nexacro.Div))
                {
                    let gParentObj = parentObj.parent;
                    if(gParentObj && (gParentObj instanceof nexacro.Form))
                    {
                        let ggParentObj = gParentObj.parent;
                        if(ggParentObj && (ggParentObj instanceof nexacro.ChildFrame))
                        {
                            if(ggParentObj.parent===mainFrame)
                            {
                                return true;
                            }
                        }
                    }
                }
            }
            return false;
        },
        /**
         * 메인화면 검증
         * @param  {nexacro.Form} [formObj] : 검증대상 form
         * @return {String} 메인화면 form 일 시 하위업무화면 form ID
         *                  메인화면 form 아닐 시 null
         * 메인화면여부
         * - 업무 Form depth : frameSet > childFrame > 메인 Form
         */
        getIdOfMainForm : function(formObj)
        {
            if(!formObj){return null;}
            if(formObj instanceof nexacro.TitleBarControl){return null;}
            if(formObj instanceof nexacro.Form)
            {
                if(formObj.name=="form"){return null;}
                let mainFrame = nexacro.getApplication().gvMain;
                let parentObj = formObj.parent;
                if(parentObj && (parentObj instanceof nexacro.ChildFrame))
                {
                    if(parentObj.parent===mainFrame)
                    {
                        return parentObj.id;
                    }
                }
            }
            return null;
        },
        /**
         * QuickView 검증
         * @param  {nexacro.Form} [formObj] : 검증대상 form
         * @return {String} quickview form 일 시 해당 form name
         *                  quickview form 아닐 시 null
         */
        getIdOfQuickView : function(formObj)
        {
            if(!formObj){return null;}
            if(formObj instanceof nexacro.TitleBarControl){return null;}
            if(formObj instanceof nexacro.Form){
                let parent = formObj.parent;
                if(parent && (parent instanceof nexacro.ChildFrame) && parent.id=="QuickViewFrame")
                {
                    return formObj.name;
                }
            }
            return null;
        },
        /**
         * Popup 검증
         * @param  {nexacro.Form} [formObj] : 검증대상 form
         * @return {String} popup form 일 시 opener frame ID (없을 시 해당 form name)
         *                  popup form 아닐 시 null
         */
        getIdOfPopupForm : function(formObj)
        {
            if(!formObj){return null;}
            if(formObj instanceof nexacro.TitleBarControl){return null;}
            if(formObj instanceof nexacro.Form){
                let parent   = formObj.parent;
                if(parent && (parent instanceof nexacro.ChildFrame))
                {
                    let parentId = parent.id;
                    let gParent = parent.parent;
                    if(gParent && (gParent instanceof nexacro.ChildFrame))
                    {
                        let popupArr = nexacro.getPopupFrames(gParent);
                        if(popupArr[parentId]===parent)
                        {
                            if(gParent._pageId)
                            {
                                return gParent._pageId;
                            }
                            return formObj.name;
                        }
                    }
                }
            }
            return null;
        },
        /**
         * Global 검증
         * @param  {nexacro.Form} [formObj] : 검증대상 form
         * @return {String} global form 일 시 form ID
         *                  global form 아닐 시 null
         */
        getIdOfGlobalForm : function(formObj)
        {
            let application = nexacro.getApplication();
            let gvArray = application.all._idArray;
            for(let i=0;i<gvArray.length;i++)
            {
                let gv  = gvArray[i];
                let obj = application[gv];
                if(obj && (obj instanceof nexacro.ChildFrame))
                {
                    obj = obj.getForm();
                }
                
                if(obj && obj===formObj)
                {
                    return obj.name||"form";
                }
            }
            return null;
        },
        /**
         * message Popup 검증
         * @param  {nexacro.Form} [formObj] : 검증대상 form
         * @return {String} message popup form 일 시 opener frame ID (없을 시 해당 form name)
         *                  message popup form 아닐 시 null
         * message popup 여부
         * form url : Comm::Comm_Alert.xfdl
         *            Comm::Comm_Confirm.xfdl
         *            Comm::Comm_Confirm_Risk.xfdl
         *            Comm::Comm_ToastrAlert.xfdl
         *            Comm::Comm_Prompt.xfdl
         *            Comm::Comm_WaitCursor.xfdl
         */
        getIdOfMsgPopupForm : function(formObj)
        {
            let popupId = this.getIdOfPopupForm(formObj);
            if(popupId){
                let parent   = formObj.parent;
                if(parent && (parent instanceof nexacro.ChildFrame))
                {
                    let formUrl = parent.formurl;
                    switch(formUrl)
                    {
                        case "Comm::Comm_Alert.xfdl"       :
                        case "Comm::Comm_Confirm.xfdl"     :
                        case "Comm::Comm_Confirm_Risk.xfdl":
                        case "Comm::Comm_ToastrAlert.xfdl" :
                        case "Comm::Comm_Prompt.xfdl"      :
                        case "Comm::Comm_WaitCursor.xfdl"  :
                            return popupId;
                            break;
                        default:
                            break;
                    }
                }
            }
            return null;
        },
        /**
         * url form 검증
         * @param  {nexacro.Form} [formObj] : 검증대상 form
         * @return {String} url로 호출된 form 일 시 해당 form name
         *                  url로 호출된 form 아닐 시 null
         */
        getIdOfUrlForm : function(formObj)
        {
            if(formObj==null){return null;}
            if(!(formObj instanceof nexacro.Form)){return null;}
            if(formObj instanceof nexacro.TitleBarControl){return null;}
            let parent = formObj.parent;
            if(parent && (parent instanceof nexacro.Frame))
            {
                if(parent.formurl)
                {
                    return formObj.name||"urlForm";
                }
            }
            else if(parent.url)
            {
                return formObj.name||"urlForm";
            }
