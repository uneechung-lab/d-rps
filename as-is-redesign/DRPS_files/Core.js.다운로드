     JsNamespace.declare("Drps.Core",{
        /**
         * Form 공통 Init
         * @param {nexacro.Form} [formObj] : 대상 form
         * @return N/A
         * init 본함수 : _formInit
         */
        formInit : function(formObj)
        {
            if(!formObj){return;}
            let pageId       = this.getIdOfWorkForm (formObj);
            let quickViewId  = this.getIdOfQuickView(formObj);
            let popupId      = this.getIdOfPopupForm(formObj);
            let msgPopupId   = this.getIdOfMsgPopupForm(formObj);
            let globalFormId = this.getIdOfGlobalForm(formObj);
            if(pageId || quickViewId || popupId){
                if(!msgPopupId && !globalFormId)
                {
                    Drps.Util.init(formObj);
                }
                this._formInit(formObj);
            }
        },
        /**
         * Form 공통 Init
         * @param {nexacro.Form} [formObj] : 대상 form
         * @return N/A
         * 화면 open 공통
         * - 화면 open 이력 추가
         * titleText 처리
         * - bottom Tab text와 동기화
         * 하위 컴포넌트 처리
         * - Grid       : initGrid
         * - Button     : initButton
         * - Calendar   : initCalendar
		 * - WebBrowser : initWebBrowser
         * - Spin       : initSpin
         * - Combo      : initCombo
         * - Tab        : _initRecursion
         * - Form       : _initRecursion
         * - Frame      : _initRecursion
         * - Div        : _initRecursion
         */
        _formInit : function(formObj)
        {
            formObj._userInit = true;
            
            let pageId        = this.getIdOfWorkForm(formObj);
            if(pageId)
            {
                if(!formObj._pageId)
                {
                    formObj._pageId = pageId;
                }
                let bottomForm  = nexacro.getApplication().gvBottom;
                let bottomTab   = bottomForm.Tab_menu00;
                let tabIndex    = bottomTab.tabindex;
                let tabPage     = bottomTab.tabpages[tabIndex];
                let tabPageName = tabPage.text;
                let mainFrame   = nexacro.getApplication().gvMain;
                let pageFrame   = mainFrame[pageId];
                
                pageFrame.set_titletext(tabPageName);
                
                // form id 추출
                let scrinId = pageFrame._formUrl||formObj._orgurl||"";
                if(scrinId.indexOf("::") > -1)
                {
                    scrinId = scrinId.split("::")[1];
                }
                if(scrinId.endsWith(".xfdl"))
                {
                    scrinId = scrinId.split(".xfdl")[0];
                }
                if(Drps.Util.isNull(scrinId))
                {
                    scrinId = "undefined";
                }

                // 화면 이력 추가
//                 formObj.tisLongTransaction(
//                                            {
//                                             svcID          : "insertHist"
//                                            ,url            : "/BC1002/insertPgmReadngHist.do"
//                                            ,argument       : "scrinId=" + scrinId
//                                            ,isToastr       : false
//                                            ,showWaitCursor : false
//                                            ,httptimeout    : 30
//                                            }
//                                           );
                
            }
            
            let compObjs = formObj.components;
            let compArr  = [];
            let formArr  = [];
            
            for(let i=0;i<compObjs.length;i++)
            {
                let compObj = compObjs[i];
                // Form
                if(compObj instanceof nexacro.Form)
                {
                    formArr.push(compObj);
                }
                // Frame, Div
                else if(compObj.form && compObj.form instanceof nexacro.Form)
                {
                    compArr.push(compObj);
                    formArr.push(compObj.form);
                }
                // Tab
                else if(compObj instanceof nexacro.Tab)
                {
                    compArr.push(compObj);
                    let tabpages = compObj.tabpages;
                    if(tabpages && tabpages.length)
                    {
                        for(let x=0;x<tabpages.length;x++)
                        {
                            let tabpage = tabpages[x];
                            let tabForm = tabpage.form;
                            if(tabForm)
                            {
                                formArr.push(tabForm);
                            }
                        }
                    }
                }
                else
                {
                    compArr.push(compObj);
                }
            }
            
            // compArr loop
            for(let i=0;i<compArr.length;i++)
            {
                let compObj = compArr[i];
                // Grid
                if(compObj instanceof nexacro.Grid)
                {
                    this.initGrid(compObj);
                }
                // Button
                else if(compObj instanceof nexacro.Button)
                {
                    this.initButton(compObj);
                }
                // Calendar
                else if(compObj instanceof nexacro.Calendar)
                {
                    this.initCalendar(compObj);
                }
                // WebBrowser
                else if(compObj instanceof nexacro.WebBrowser)
                {
                    this.initWebBrowser(compObj);
                }
                // Spin
                else if(compObj instanceof nexacro.Spin)
                {
                    this.initSpin(compObj);
                }
                // Combo
                else if(compObj instanceof nexacro.Combo)
                {
                    this.initCombo(compObj);
                }
            }
            
            // formArr loop (recursion) 
            for(let i=0;i<formArr.length;i++)
            {
                let form = formArr[i];
                form._pageId = formObj._pageId;
                if(typeof form.__fixedProps=="undefined")
                {
                    form.__fixedProps = {};
                }
                form.__fixedProps["_pageId"] = form._pageId;
                this._initRecursion(form);
            }
            
        },
        _initRecursion : function(formObj)
        {
            if(formObj._userInit){return;}
            this._formInit(formObj);
        },
        /**
         * Grid Init
         * @param {nexacro.Grid} [gridObj] 대상 grid
         * @return N/A
         * 최초조회 처리
         * _isSearched = false
         */
        initGrid : function(gridObj)
        {
            gridObj._isSearched = false;
        },
        /**
         * Grid 연속조회 세팅
         * @param {nexacro.Grid}   [gridObj ] : 대상 grid
         * @param                  [userNext] 
         *        {nexacro.Button}            : 연속조회 Button
         *     or {Function}                  : 연속조회시 호출 Function
         *     or {String}                    : Button id 혹은 Function 명
         * @param {nexacro.Form}   [formObj ] : userNext 선언된 form(미입력시 ffobj 적용)
         * next 조회 처리
         * -- Button   : click 이벤트 수행
         * -- Function : 해당 function 호출
         */
        setGridNext : function(gridObj, userNext, formObj)
        {
            if(!formObj || !(formObj instanceof nexacro.Form))
            {
                formObj = Drps.Util.ffobj;
            }

            if(typeof userNext==="string")
            {
                let allObj  = this.getAll(Drps.Util.ffobj,userNext);
                let targets = allObj.targets;
                for(let i=0;i<targets.length;i++)
                {
                    let targetObj = targets[i];
                    let rootForm  = targetObj.rootForm;
                    let target    = targetObj.target;
                    if(rootForm===Drps.Util.ffobj){
                        if(typeof target==="function" || (target instanceof nexacro.Button))
                        {
                            userNext = target;
                            break;
                        }
                    }
                    else if(rootForm===formObj)
                    {
                        if(typeof target==="function" || (target instanceof nexacro.Button))
                        {
                            userNext = target;
                            break;
                        }
                    }
                }
            }
            if(userNext){
                if(userNext instanceof nexacro.Button)
                {
                    gridObj._nextFuncTmp = function(obj,e)
                    {
                        if(e.type && e.type.endsWith("last") && gridObj._nextPageYn=="Y")
                        {
                            userNext.click();
                        }
                    };
                }
                else if(typeof userNext === "function")
                {
                    userNext = userNext.bind(formObj);
                    gridObj._nextFuncTmp = function(obj,e)
                    {
                        if(e.type && e.type.endsWith("last") && gridObj._nextPageYn=="Y")
                        {
                            userNext();
                        }
                    };
                }
                if(gridObj._nextFuncTmp)
                {
                    if(gridObj._nextFunc && typeof gridObj._nextFunc==="function")
                    {
                        gridObj.removeEventHandler("onvscroll",gridObj._nextFunc,gridObj);
                    }
                    gridObj._nextFunc = gridObj._nextFuncTmp;
                    gridObj.addEventHandler("onvscroll",gridObj._nextFunc,gridObj);
                    delete gridObj._nextFuncTmp;
                }
            }
        },
        /**
         * Button Init
         * @param {nexacro.Button} [btnObj ] : 대상 button
         * @return N/A
         * HOTKEY 제어
         * - HOTKEY 전용버튼 생성[hidden 처리]
         */
        initButton : function(btnObj)
        {
            if(btnObj==null){return;}
            if(!(btnObj instanceof nexacro.Button)){return;}
            if(btnObj.hotkey)
            {
                let btnId = "__hotKey"+btnObj.hotkey+"__";
                if(!Drps.Util.ffobj[btnId])
                {
                    let hotkeyBtn = new Button();
                    hotkeyBtn.init(btnId);
                    hotkeyBtn.set_hotkey(btnObj.hotkey);
                    hotkeyBtn.set_visible(false);
                    Drps.Util.ffobj.addChild(btnId, hotkeyBtn);
                    hotkeyBtn.keyBtns = [btnObj];
                    if(hotkeyBtn._onHotkeyEvent)
                    {
                        hotkeyBtn.removeEventHandler("onclick",hotkeyBtn._onHotkeyEvent,hotkeyBtn);
                    }
                    hotkeyBtn._onHotkeyEvent = function(obj, e)
                                               {
                                                   for(let i=0;i<obj.keyBtns.length;i++)
                                                   {
                                                       let btnObj = obj.keyBtns[i];

                                                       if(btnObj._isVisible())
                                                       {
                                                           btnObj.setFocus();
                                                           btnObj.click();
                                                           return;
                                                       }
                                                   }
                                               };
                    hotkeyBtn.addEventHandler("onclick",hotkeyBtn._onHotkeyEvent,hotkeyBtn);
                    hotkeyBtn.show();
                }
                let hotkeyObj = Drps.Util.ffobj[btnId];
                setHotkeys :
                {
                    btnObj.set_hotkey("");
                    for(let i=0;i<hotkeyObj.keyBtns.length;i++)
                    {
                        if(hotkeyObj.keyBtns[i]===btnObj)
                        {
                            break setHotkeys;
                        }
                    }
                    hotkeyObj.keyBtns.push(btnObj);
                }
            }
        },
        _setAuthCover : function(btnObj)
