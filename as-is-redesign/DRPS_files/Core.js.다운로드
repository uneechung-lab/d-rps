            if(!(btnObj instanceof nexacro.Button)){return;}
            let formObj = btnObj.parent;
            if(formObj instanceof nexacro.Form)
            {
                // formObj = formObj;
            }
            else if(formObj.form && (formObj.form instanceof nexacro.Form))
