        /**
         * @class excel export <br>
         * @param {nexacro.Grid} [objGrid    ] - Grid Object	
         * @param {String      } [sSheetName ] - sheet name
         * @param {String      } [sFileName  ] - file name
         * @param {Boolean     } [bPromptResn] - 사유입력여부(true:입력,false:미입력)(default:true)
         * @param {Boolean     } [bOpen      ] - 다운로드 후 파일 open 여부(true:open, false:unopen)(default:true)
         * @return N/A
         * @example
         * Drps.Excel.excelExport(this.grid_export, "SheetName","");
         * @memberOf Drps.Excel
         * 2020.01.20 김준권 다중 그리드 멀티시트 엑셀 처리
         * - @param {Object} objGrid
         * -> @param                  objGrid
         *           {nexacro.Grid  } : 대상 Grid Object
         *           {nexacro.Grid[]} : 멀티시트 대상 Grid Array
         *    @param                  sSheetName
         *           {String        } : sheet name
         *           {String[]      } : 멀티시트 대상 sheet name Array
         */
        excelExport2 : function(objGrid,  sSheetName, sFileName, bPromptResn, bOpen)
        {
            if(!objGrid)
            {
                Drps.Core.showError("undefined parameter : objGrid - " + objGrid);
                return;
            }
            let totCnt = 0;
            if(objGrid instanceof Array)
            {
                for(let i in objGrid)
                {
                    let gridObj = objGrid[i];
                    if(!gridObj)
                    {
                        Drps.Core.showError("undefined : objGrid["+i+"] - " + gridObj);
                        return;
                    }
                    else if(gridObj instanceof nexacro.Grid)
                    {
                        totCnt += gridObj.rowcount;
                    }
                    else
                    {
                        Drps.Core.showError("illegal : objGrid["+i+"] - " + gridObj);
                        return;
                    }
                }
            }
            else if(objGrid instanceof nexacro.Grid)
            {
                totCnt = objGrid.rowcount;
            }
            else
            {
                Drps.Core.showError("illegal parameter : objGrid - " + objGrid);
            }
            
            var ffobj = Drps.Util.ffobj;
            
            var objGrid_excel = objGrid;
            
            var regExp = /[`~!@#$%^&*|\\\'\";:\/?]/g;  // 엑셀에서 지원하지않는 모든 문자

            //fileName nullcheck
            sFileName = Drps.Util.isNull(sFileName) ? "ExcelExport_"+Drps.Util.getDate() : sFileName;

            sFileName = sFileName.replace(regExp,"");	//파일명에 특수문자 제거
            
            /**
             * 엑셀 다운로드 사유입력 처리
             */
            if(bPromptResn!==false && !Drps.Util.resnRegPopup(sFileName, totCnt))
            {
                return;
            }
            
            // sSheetName = sSheetName.replace(regExp,""); //시트명에 특수문자 제거  // 2020.01.20 김준권 line 이동
            
            // 2020.01.20 김준권 type별 분기처리, 들여쓰기 처리 START
            if(sSheetName && typeof sSheetName == "string")
            {
                //sheetName nullcheck
                sSheetName = Drps.Util.isNull(sSheetName) ? "sheet1" : sSheetName;
                sSheetName = sSheetName.replace(regExp,""); //시트명에 특수문자 제거  // 2020.01.20 김준권 line 이동
                //sheetName 30이상일경우 기본시트명
                if( String(sSheetName).length > 30 ){
                    sSheetName =  "sheet1";
                }
            }
            // 2020.01.20 김준권 type별 분기처리, 들여쓰기 처리 END
            
            var svcUrl = "svcurl::XExportImport.nx";
            ffobj.objExport = null
            ffobj.objExport = new ExcelExportObject();

            ffobj.objExport.objgrid = objGrid_excel;
            ffobj.objExport.set_exporturl(svcUrl);
            ffobj.objExport.set_transferrowcount(5000);
            // 2020.01.20 김준권 멀티시트 처리 - 그리드 배열 처리 START
            // ffobj.objExport.addExportItem(nexacro.ExportItemTypes.GRID, objGrid_excel, sSheetName+"!A1","allband","allrecord");
            if(objGrid_excel && (objGrid_excel instanceof nexacro.Grid))
            {
                let sSheetNameTmp = "";
                if(typeof sSheetName=="string")
                {
                    sSheetNameTmp = sSheetName;
                }
                else if(sSheetName && (sSheetName instanceof Array) && sSheetName[0])
                {
                    sSheetNameTmp = sSheetName[0];
                }
                else
                {
                    sSheetNameTmp = "sheet1";
                }
                ffobj.objExport.addExportItem(nexacro.ExportItemTypes.GRID, objGrid_excel, sSheetNameTmp+"!A1","allband","allrecord");
            }
            else
            {
                let arrSheetName = [];
                if(sSheetName==="sheet1")
                {
                    sSheetName = "sheet";
                }
                
                if(typeof sSheetName=="string")
                {
                    arrSheetName.push();
                }
                else if(sSheetName && (sSheetName instanceof Array))
                {
                    arrSheetName = sSheetName;
                }
                
                for(let x=arrSheetName.length;x<objGrid_excel.length;x++)
                {
                    if(typeof sSheetName=="string")
                    {
                        arrSheetName.push(sSheetName+x);
                    }
                    else
                    {
                        arrSheetName.push("sheet"+x);
                    }
                    
                }
                
                for(let i=0;i<objGrid_excel.length;i++)
                {
                    let objGrid_excelTmp = objGrid_excel[i];
                    let sSheetNameTmp    = arrSheetName.shift();
                    ffobj.objExport.addExportItem(nexacro.ExportItemTypes.GRID, objGrid_excelTmp, sSheetNameTmp+"!A1","allband","allrecord");
                }
            }
            // 2020.01.20 김준권 멀티시트 처리 - 그리드 배열 처리 END
            ffobj.objExport.set_exportfilename(sFileName);	
            
            ffobj.objExport.set_exporteventtype("itemrecord");
            ffobj.objExport.set_exportuitype("none");
            ffobj.objExport.set_exportmessageprocess("");
            ffobj.objExport.addEventHandler("onsuccess", this.exportOnsuccess, this);	
            ffobj.objExport.addEventHandler("onerror", this.exportOnerror, this);	
            
            let sActiveMode = "active";
            if(bOpen===false)
            {
                sActiveMode = "noactive";
            }

            ffobj.objExport.set_exportactivemode(sActiveMode);
            ffobj.objExport.__opener = ffobj;
            Drps.Util.waitCursor(ffobj,true);
            try{
                var result = ffobj.objExport.exportData();
            }catch(e){
                Drps.Util.waitCursor(ffobj,false);
                throw e;
            }
        },
