    this.Environment_onerror = function(obj,e)
    {
        if(e.errortype==="CommunicationError"                       &&
           (e.statuscode==-1||e.statuscode==307||e.statuscode==404) &&
           Drps.Core && typeof Drps.Core.getIdOfWorkForm=="function")
        {
            let fromObj = e.fromobject;
            if(Drps.Core.isWorkForm(fromObj) && typeof nexacro.getApplication().gfnArrangeFrame=="function")
            {
                if(fromObj._url==e.requesturi)
                {
                    Drps.Util.alert("요청하신 페이지가 존재하지 않습니다.");
                    nexacro.getApplication().gfnArrangeFrame("close");
                }
