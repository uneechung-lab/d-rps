         datasetIsUpdated : function (objDs)
         {
             if(typeof objDs=="undefined")
             {
                 throw new Error("해당 데이터셋이 존재하지 않습니다.");
             }
             let ret = false;
             if (objDs.getDeletedRowCount() > 0) 
             {
                 ret = true;
             }
             else{
                 for(var i = 0 ; i < objDs.getRowCountNF() ; i++)
                 {
                     if(objDs.getRowTypeNF(i) == Dataset.ROWTYPE_INSERT || objDs.getRowTypeNF(i) == Dataset.ROWTYPE_UPDATE || objDs.getRowTypeNF(i) == Dataset.ROWTYPE_DELETE)
                     {
                         ret = true;
