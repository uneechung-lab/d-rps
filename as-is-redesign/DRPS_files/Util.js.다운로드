          * @param {Array} arrColumn - 복사 제외되는 컬럼배열
          * @return
          * @example Drps.Util.addCopyRow(this.dsUserList, ["userId", "passwd", "passwdChngDttm", "passwdErrCnt", "preAccsDttm", "preAccsIp"]);
          * @memberOf Drps.Util
          */ 
         addCopyRow : function(objDs, arrColumn)
         {
             let nRowPos = objDs.rowposition;
             
             if(nRowPos == -1)
             {
                 objDs.addRow();
                 return;
             }
             
             let nAddRow = objDs.addRow();
             objDs.set_enableevent(false);
             for(let nCol=0;nCol<objDs.colcount;nCol++)
             {
                 let sColId = objDs.getColID(nCol);
                 
                 // arrColumn에 없는 컬럼ID의 자료만 복사한다.
                 if(arrColumn.indexOf(sColId) == -1)
                 {
                     objDs.setColumn(nAddRow, sColId, objDs.getColumn(nRowPos, sColId));
                 }
             }
             objDs.set_enableevent(true);
