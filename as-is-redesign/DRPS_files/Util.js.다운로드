         /**
          * @class 팝업오픈
          * @param {String} sPopupId - 팝업ID
          * @param {String} sUrl  - 팝업URL
          * @param {String} [oArg] - 전달값
          * @param {String} [sPopupCallback] - 팝업콜백
          * @param {Object} [oOption] - 팝업옵션 <br>
          *  oOption.top : 상단 좌표 <br>
          *  oOption.left : 좌측 좌표 <br>
          *  oOption.width : 넓이 <br>
          *  oOption.height : 높이 <br>
          *  oOption.popuptype : 팝업종류(modal:showModal, modeless:application.open, modalwindow:showModalWindow) <br>
          *  oOption.layered : 투명 윈도우 <br>
          *  oOption.opacity : 투명도 <br>
          *  oOption.autosize : autosize <br>
          * @param {nexacro.Form} [opener] - opener form(default ffobj)
          * @return N/A
          * @example
          * Drps.Util.openPopup(this);
          * @memberOf Drps.Popup
          * 2020.01.14 김준권 popup title icon hidden
          *                   popup showtitlebar option에 추가
          * 2020.01.29 김준권 popup default modalwindow로 변경
          */
         openPopup : function ( sPopupId, sUrl, oArg, sPopupCallback, oOption, opener)
         {
             var ffobj = opener||this.ffobj;
             var objApp = nexacro.getApplication();
             var nLeft = -1;
             var nTop = -1;
             var nWidth = -1;
             var nHeight = -1;
             var bShowTitle = false;
             var bShowTitleIcon = false; // 2020.01.14 김준권
             var bShowStatus = false;    
             var sPopupType = "modal";
             var bLayered = false;
             var nOpacity = 100;
             var bAutoSize = false;
             var bResizable = false;
             var sOverlayColor = null;
             let oPopupCallback = this._popupCallback;
             var sTitleText = "";
             
             oArg    = oArg   ||{};
             oOption = oOption||{};
             
             if(!oArg._params)
             {
                 oArg._params = {_openerId:ffobj._openerId||ffobj._pageId};
             }
             else
             {
                 oArg._params._openerId = ffobj._openerId||ffobj._pageId;
             }
 
             for (var key in oOption) {
                if (oOption.hasOwnProperty(key)) {
                     switch (key) 
                     {
                         case "top":             
                             nTop = parseInt(oOption[key]);
                             break;
                         case "left":
                             nLeft = parseInt(oOption[key]);
                             break;
                         case "width":
                             nWidth = parseInt(oOption[key]);
                             break;
                         case "height":
                             nHeight = parseInt(oOption[key]);
                             break;
                         case "popuptype":
                             sPopupType = oOption[key];
                             break;
                         case "layered":
                             bLayered = oOption[key];
                             break;
                         case "opacity":
                             nOpacity =oOption[key];
                             break;
                         case "autosize":
                             bAutoSize = oOption[key];
                             break;
                         case "showtitlebar":
                             bShowTitle = oOption[key];
                         case "resizable" :
                             bResizable = oOption[key];
                         case "overlaycolor" :
                             sOverlayColor = oOption[key];
                     }   
                 }
             }
			 
             var sOpenalign = "";
             if(nLeft == -1 && nTop == -1) 
             {       
                 sOpenalign = "center middle";
                 nLeft   =  (objApp.mainframe.width / 2) - Math.round(nWidth / 2);
                 nTop    = (objApp.mainframe.height / 2) - Math.round(nHeight / 2) ;     
             }else{
                 nLeft   =  ffobj.getOffsetLeft() + nLeft;
                 nTop   =  ffobj.getOffsetTop() + nTop;
             }
                     
             if(nWidth == -1 || nHeight == -1)
             {
                 bAutoSize = true;
             }
                 
             var objParentFrame = ffobj.getOwnerFrame()||nexacro.getApplication().gvRoot;
             
             if(this.isNull(sPopupCallback))
             {
                 oPopupCallback = oPopupCallback.bind(this);
             }
             else if(typeof sPopupCallback==="function")
             {
                 oPopupCallback = sPopupCallback;
             }
             else if(typeof sPopupCallback==="string" && ffobj[sPopupCallback])
             {
                 oPopupCallback = ffobj[sPopupCallback];
             }
             else
             {
                 oPopupCallback = sPopupCallback;
             }
			 
             if(sPopupType == "modeless")
             {
                 // var sOpenStyle= "showtitlebar=true showstatusbar=false resizable=true autosize=true"; // 2020.01.14 김준권
                 // var sOpenStyle= "showtitlebar=true showstatusbar=false resizable=true autosize=true showtitleicon=false";
                 var sOpenStyle  = "showtitlebar="+bShowTitle;
                     sOpenStyle += " layered="+bLayered;
                     sOpenStyle += " showstatusbar=false";
                     sOpenStyle += " resizable=true";
                     sOpenStyle += " autosize="+bAutoSize;
                     sOpenStyle += " showtitleicon=false";
                         
                 nexacro.open(sPopupId,sUrl,objParentFrame,oArg,sOpenStyle,nLeft, nTop, nWidth, nHeight, ffobj);
             }
             else if(sPopupType == "modalwindow")
             {
                 if(typeof oOption.showtitlebar=="undefined")
                 {
                     bShowTitle = true;
                 }
                 
                 var newChild = new nexacro.ChildFrame;
                 newChild.init(sPopupId, nLeft, nTop, nWidth, nHeight, null, null, sUrl);
                 newChild.set_dragmovetype("all");
                 newChild.set_showtitlebar(bShowTitle);    //titlebar는 안보임
                 newChild.set_showtitleicon(bShowTitleIcon); //titleicon 표시여부 // 2020.01.14 김준권
                 newChild.set_autosize(bAutoSize);   
                 newChild.set_resizable(bResizable);    //resizable 안됨
                 if(!this.isNull(sTitleText)) newChild.set_titletext(sTitleText);
                 newChild.set_showstatusbar(bShowStatus);    //statusbar는 안보임
                 newChild.set_openalign(sOpenalign);
                 newChild.set_layered(bLayered);
                 if(sOverlayColor==null)
                 {
                     // newChild.set_overlaycolor("transparent");
                 }
                 else
                 {
                     newChild.set_overlaycolor(sOverlayColor);
                 }
 
                 var mainFrameWin = ffobj._getRootWindow();
                 var oldFocusList = mainFrameWin.getCurrentFocusPaths();
                 var oldFocus     = null;
                 if(oldFocusList.length)
                 {
                     oldFocus = oldFocusList[oldFocusList.length-1];
                 }
                 
                 let gvRoot     = nexacro.getApplication().gvRoot;
                 let openstatus = gvRoot.openstatus;
                 if(gvRoot && typeof gvRoot.set_openstatus=="function" && openstatus!="maximize")
                 {
                    gvRoot.set_openstatus("restore");
                 }
 
                 var rtn = system.showModalWindow(newChild, sPopupId, objParentFrame, oArg, ffobj);
                 if(oldFocus && typeof oldFocus.setFocus=="function")
                 {
                     oldFocus.setFocus(false);
                 }

                 try
                 {
                     return Function('"use strict";return ('+rtn+')')();
                 }catch(e)
                 {
                     return rtn;
                 }
 
             }   
             else if(sPopupType == "modal")
             {
                 if(typeof oOption.showtitlebar=="undefined")
                 {
                     bShowTitle = true;
                 }
                 
                 var newChild = new nexacro.ChildFrame;
                 newChild.init(sPopupId, nLeft, nTop, nWidth, nHeight, null, null, sUrl);
                 
                 newChild.set_dragmovetype("all");
                 newChild.set_showtitlebar (bShowTitle);
                 newChild.set_showtitleicon(bShowTitleIcon);
                 newChild.set_autosize(bAutoSize);   
                 newChild.set_resizable(bResizable);
                 if(!this.isNull(sTitleText)) newChild.set_titletext(sTitleText);
                 newChild.set_showstatusbar(bShowStatus);
                 newChild.set_openalign(sOpenalign);
                 newChild.set_layered(bLayered);
				 newChild.set_overlaycolor(sOverlayColor);
                 newChild.showModal(sPopupId, objParentFrame, oArg, ffobj, oPopupCallback); 
             }
             else
             {
                 trace("illegal popup type : " + sPopupType);
                 return null;
             }
         },
 
