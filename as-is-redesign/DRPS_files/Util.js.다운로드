         /**
         * @class 팝업오픈 공통 함수
         * @param {Object} 호출 화면 객체
         * @param {String} 팝업ID 고유한 문자열로 설정
         * @param {boolean} 버튼 클릭시 false, 데이터 변경 시 true
         *               false 인 경우 명칭에 값이 있더라도 팝업의 명칭 값을 비우고 무조건 팝업 오픈, 팝업에서 취소 시 기존 부모창의 데이터를 수정하지 않음
         *               true 인 경우 
         *                       - 1. 건수 조회 후 1건이면 팝업을 호출하지 않고 받은 1건의 데이터를 세팅 아니면 팝업 호출
         *                       - 2. 입력한 값이 그대로 팝업의 명칭 값에 올라감
         *                       - 3. 입력값을 팝업창으로부터 받아온 값을 기존 부모창에 세팅
         *                       - 4. 팝업창에서 취소 시 기존 부모창의 데이터도 지움
         *                       - 5. 후작업을 위해 팝업 호출 후 데이터를 반환함
         * @return {Object} 팝업 호출 후 리턴받는 객체
         * @example 
         *       Drps.Util.openCommonPopup(this, "AT1044P02UpperAcntctCd", false);
         * @memberOf Drps.Util
         */
         openCommonPopup : function (objForm, sPopupId, IsValue)
         {
             let objParam = objForm["__tmp"+sPopupId];
             let arrAddParam = objParam.__arrAddParam;
             
             let objSearch = {};
             
             let objDs = objParam.__objDs;
             let rcvCodeColumn = objParam.__sCodeParam.split("=")[0];
             let rtnCodeColumn = objParam.__sCodeParam.split("=")[1];
             
             let rcvNameColumn = objParam.__sNameParam.split("=")[0];
             let rtnNameColumn = objParam.__sNameParam.split("=")[1];
             
             // nameParam의 부모창 컬럼id와 searchParam의 부모창 컬럼id가 일치하는 경우를 수정하는 값의 파라미터로 인식함
             let sSearchNameParam;
              // 파라미터 오브젝트 생성
             for(let key in objParam.__objSearchParam)
             {
                 let paramSplit = objParam.__objSearchParam[key].split(".");
                 let paramDs = objForm[paramSplit[0]];
                 let paramColumn = paramSplit[1];
                 
                 if(rcvNameColumn == paramColumn)
                 {
                     sSearchNameParam = key;
                 }
                 objSearch[key] = paramDs.getColumn(paramDs.rowposition, paramColumn);
             }
             
             // 임시 데이터셋 생성
             Drps.Util.createDataset(objForm, "__dsTempInput", objSearch);
             Drps.Util.createDataset(objForm, "__dsTempOutput");
             
             // 명 데이터 수정 시
             if(IsValue)
             {
                 // 명 데이터가 빈값이라면 코드값도 빈값처리
                 if(!objDs.getColumn(objDs.rowposition, rcvNameColumn))
                 {
                     objDs.set_enableevent(false);
                     objDs.setColumn(objDs.rowposition, rcvCodeColumn, "");
                     for(let i=0;i<arrAddParam.length;i++)
                     {
                         objDs.setColumn(objDs.rowposition, arrAddParam[i].split("=")[0], "");
                     }
                     objDs.set_enableevent(true);
                     return;
                 }
                 
                 // 자동세팅기능 사용여부
                 if(objParam.__autoable)
                 {
                     // 건수 조회를 위한 통신 호출
                     objForm.svcTransaction({
                           svcID          : "__commonPopupCntSearch"
                         , url            : objParam.__sPopupTran
                         , inDataset      : objParam.__sInDataset+"=__dsTempInput"
                         , outDataset     : "__dsTempOutput="+objParam.__sOutDataset
                         , pageSize       : 2 
                         , async          : false
                     });
                 }
             }
             
             
             objDs.set_enableevent(false);
             
             let objData;
             
             // 1건 조회 시 받아온 자료를 명, 코드에 세팅
             if ( objForm.__dsTempOutput.getRowCount() == 1) {
                 let codeValue = objForm.__dsTempOutput.getColumn(0, rtnCodeColumn);
                 let nameValue = objForm.__dsTempOutput.getColumn(0, rtnNameColumn);
                 
                 objDs.setColumn(objDs.rowposition, rcvCodeColumn, codeValue);
                 objDs.setColumn(objDs.rowposition, rcvNameColumn, nameValue);
                 
                 for(let i=0;i<arrAddParam.length;i++)
                 {
                     let addValue = objForm.__dsTempOutput.getColumn(0, arrAddParam[i].split("=")[1]);
                     
                     objDs.setColumn(objDs.rowposition, arrAddParam[i].split("=")[0], addValue);
                 }
                 
                 objData = Drps.Util.strToJson(Drps.Util.getSelectedDataRowset(objForm.__dsTempOutput));
             } 
             // 1건이 아니면 팝업 호출
             else 
             {
                 let objArg = {};
                 
                 // 버튼을 통해 팝업을 호출한 경우 명 값을 팝업파라미터에서 삭제
                 if(!IsValue)
                 {
                     delete objSearch[sSearchNameParam];
                 }
             
                 // 팝업호출
                 objData = Drps.Util.openPopup(sPopupId, objParam.__sPopupUrl, objSearch);    
                 
                 // 데이터가 있다면 받은 데이터 세팅
                 if (objData) 
                 {
                     objDs.setColumn(objDs.rowposition, rcvCodeColumn, objData[rtnCodeColumn]);
                     objDs.setColumn(objDs.rowposition, rcvNameColumn, objData[rtnNameColumn]);
                     
                     for(let i=0;i<arrAddParam.length;i++)
                     {
                         objDs.setColumn(objDs.rowposition, arrAddParam[i].split("=")[0], objData[arrAddParam[i].split("=")[1]]);
                     }
                 }
                 // 받은 데이터가 없다면
                 else
                 {
                     // 버튼을 통해 팝업을 호출한 경우 취소시 빈값처리를 하지 않는다.
                     if(IsValue)
                     {
                         objDs.setColumn(objDs.rowposition, rcvCodeColumn, "");
                         objDs.setColumn(objDs.rowposition, rcvNameColumn, "");
                         
                         for(let i=0;i<arrAddParam.length;i++)
                         {
                             objDs.setColumn(objDs.rowposition, arrAddParam[i].split("=")[0], "");
                         }
                     }
                 }
             }
             
             objDs.set_enableevent(true);
             
             // 후처리를 위해 팝업에서 받은 값을 그대로 반환
             return objData;
         },
         
         /**
          * @class toastrAlert 팝업오픈
          * @param {String} [msg  ] - 메세지 내용
          * @return N/A
          * @example
          * Drps.Util.toastrAlert("저장되었습니다.");
          * @memberOf Drps.Message
          */
         toastrAlert : function (msg, infoGb)
         {
             let ffobj  = Drps.Util.ffobj;
             let left   = system.screenToClientX(ffobj, 0)*-1;
             let top    = system.screenToClientY(ffobj, 0)*-1;
             let height = ffobj.getOffsetHeight();
             
             let currViewObj = {};
             if(typeof nexacro.getApplication().gfnGetCurrView=="function")
             {
                 currViewObj = nexacro.getApplication().gfnGetCurrView();
             }
 
             if(typeof currViewObj.left == "number")
             {
                 left   = currViewObj.left;
             }
             if(typeof currViewObj.top == "number")
             {
                 top    = currViewObj.top;
             }
             if(typeof currViewObj.height == "number")
             {
                 height = currViewObj.height;
             }
 
             if(!this.isNull(currViewObj.view))
             {
                 switch(currViewObj.view)
                 {
                     case "login":
                         var gvLogin = nexacro.getApplication().gvLogin;
                         if(gvLogin && gvLogin.getForm())
                         {
                             ffobj = gvLogin.getForm();
                         }
                         break;
                     case "contents":
                     case "main":
                         var gvHome = nexacro.getApplication().gvHome;
                         if(gvHome && gvHome.getForm())
                         {
                             ffobj = gvHome.getForm();
                         }
                         break;
                 }
             }
 
             let strMsg = msg;
             
             if( Drps.Util.isNull(strMsg) ) strMsg = "저장되었습니다.";
             
             // 줄바꿈 변경
             strMsg = strMsg.replace(/\\n/g, String.fromCharCode(10));
             
             let idSeq = 0;
             let strPopId = "messageToastrAlert";
             let popupFrames = nexacro.getPopupFrames(ffobj);
             
             while(popupFrames[strPopId])
             {
                 let toastrFrame = popupFrames[strPopId];
                 let toastrLeft  = toastrFrame.left;
                 let toastrTop   = toastrFrame.top;
                 
                 toastrFrame.move(toastrLeft,toastrTop-52);
                 strPopId = "messageToastrAlert_"+(++idSeq);
             }
             
             let strMsgUrl = "Comm::Comm_ToastrInfo.xfdl";
			 
			 if(infoGb == "E") {
