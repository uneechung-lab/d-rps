         /**
          * @class dataset을 object로 반환
          * @param {nexacro.Dataset} [objDs] : 대상 dataset
          * @return {Object} : 변환 Object
          *          - {Object}   [Const Columns] : Const Columns
          *             - {Object<K,V>} : const column key, value
          *          - {Object[]} [Rows         ] : data row array
          *             - {Object<K,V>} : record object
          */
         datasetToJson : function(objDs)
         {
             if(typeof objDs=="undefined"){return null;}
             if(!(objDs instanceof nexacro.Dataset)){return null;}
 
             let eolStr  = nexacro._getSSVRecordSeparator();  // end of line charcode
             let eocStr  = nexacro._getSSVUnitSeparator();  // end of column charcode
             let nullStr = String.fromCharCode(3);   // undefined charcode
 
             let dsFull  = new Dataset;
                 dsFull.loadXML(objDs.saveXML(null,"view"));
             let ssvStr   = dsFull.saveSSV(null,"view");
             let ssvArr   = ssvStr.split(eolStr);
             let constObj = {};
             let colArr   = [];
             let dataStart = -1;
 
             for(let i=0;i<ssvArr.length;i++)
             {
                 let ssvStr = ssvArr[i];
                 let lineArr = ssvStr.split(eocStr);
                 if(lineArr[0]==="_Const_")
                 {
                     for(let x=1;x<lineArr.length;x++)
                     {
                         let constArr = lineArr[x].split("=");
                         let constKey   = constArr[0].split(":")[0];
                         let constValue = constArr[1]||"";
 
                         if(constKey==nullStr)
                         {
                             constKey="";
                         }
 
                         if(constValue==nullStr)
                         {
                             constValue="";
                         }
 
                         if(constKey)
                         {
                             constObj[constKey] = constValue;
                         }
                     }
                 }
                 else if(lineArr[0]==="_RowType_")
                 {
                     for(let x=0;x<lineArr.length;x++)
                     {
                         colArr.push(lineArr[x].split(":")[0]);
                     }
                     dataStart = i+1;
                     break;
                 }
             }
 
             let retObj = {};
 
             if(Object.keys(constObj).length)
             {
                 retObj["Const Columns"] = constObj;
             }
 
             let dataArr = [];
 
             for(let i=dataStart;i<ssvArr.length;i++)
             {
                 let recordStr = ssvArr[i];
                 let recordArr = recordStr.split(eocStr);
                 if(recordArr[0]!=="N"){continue;}
                 let recordObj = {};
                 for(let x=1;x<colArr.length;x++)
                 {
                     let key   = colArr[x];
                     let value = recordArr[x]||"";
                     if(value==nullStr)
                     {
                         value="";
                     }
                     recordObj[key] = value;
                 }
                 dataArr.push(recordObj);
             }
             retObj.Rows = dataArr
             return retObj;
         },
         /**
          * date 문자열 formatting
          * @param {String} [dateStr] : date 문자열
          * @param {String} [type   ] : format type(default:yyyy-MM-DD HH24:MI:SS.FF3)
          * @return {String} format 결과 String
          * @example Drps.Util.formatDateStr("20200101","yyyy-MM-DD")
          */
         formatDateStr : function(dateStr, type)
         {
             dateStr = dateStr||"";
             if(dateStr===""){return "";}
             let propObj = {};
                 propObj.yyyy = dateStr.substring( 0, 4)||"0000";
                 propObj.MM   = dateStr.substring( 4, 6)||"00";
                 propObj.DD   = dateStr.substring( 6, 8)||"00";
                 propObj.HH24 = dateStr.substring( 8,10)||"00";
                 propObj.MI   = dateStr.substring(10,12)||"00";
                 propObj.SS   = dateStr.substring(12,14)||"00";
                 propObj.FF3  = dateStr.substring(14,17)||"000";
             if(type==null)
             {
                 type = "";
                 switch(dateStr.length)
                 {
                     case 17:
                         type = ":FF3"  + type;
                     case 14:
                         type = ":SS"   + type;
                     case 12:
                         type = ":MI"   + type;
                     case 10:
                         type = " HH24" + type;
                     case  8:
                         type = "-DD"   + type;
                     case  6:
                         type = "-MM"   + type;
                     case  4:
                         type = "yyyy"  + type;
                         break;
                     default:
                         type="";
                 }
             }
             
             return type.replace(
                                 /(yyyy|MM|DD|HH24|MI|SS|FF3)/g
                                ,function(key)
                                 {
                                     return propObj[key];
                                 }
                                );
             
         },
