         /**
         * 그리드의 Sort를 처리한다.
         * @param  {event} grid event
         * @return N/A
         * @example
         * @memberOf Util
         */
         gridSort : function(obj, e)
         {
             // 컬럼의 정렬방식을 'head'의 text에 "↑,↓"여부로 판단.
             // 이미지로 대체 가능.
             var ffobj = Drps.Util.ffobj;
             var strType = obj.getCellProperty("head", e.cell, "displaytype");
             var sConstAscMark = "▲";
             var sConstDescMark = "▼";
             
             if(strType == "tree" ||strType == "checkbox" || strType == "checkboxcontrol")
             {
                 return;
             }
 
             //var bindDs = Eco.XComp.lookup(ffobj,obj.binddataset);
             var bindDs = obj.getBindDataset();
             if(bindDs.rowcount == 0)
             {
                 return false;
             }
             
             var bindText = obj.getCellProperty("body", e.col, "text");
             if(!bindText)
             {
                 return;
             }
             var BodyColId = bindText.toString().split(":");
             bindDs.set_enableevent(false);
             
             for(var i = 0; i < obj.getCellCount("head"); i++)
             {
                 if(obj.getCellText(-1, i) == "undefined" || obj.getCellText(-1, i) == null)
                 {
                     continue;
                 }
 
                 var strHeadText = obj.getCellText(-1, i);
 
                 if(i == e.cell)
                 {
                     if(strHeadText.substr(strHeadText.length - 1) == sConstAscMark)
                     {
                         obj.setCellProperty("head", i, "text", strHeadText.substr(0, strHeadText.length - 1) + sConstDescMark);
                         bindDs.set_keystring(("S:-" + BodyColId[1]));
                     }else if(strHeadText.substr(strHeadText.length - 1) == sConstDescMark){
                         obj.setCellProperty("head", i, "text", strHeadText.substr(0, strHeadText.length - 1) + sConstAscMark);
                         bindDs.set_keystring(("S:+" + BodyColId[1]));
                     }else{
                         obj.setCellProperty("head", i, "text", strHeadText + sConstAscMark);
                         bindDs.set_keystring(("S:+" + BodyColId[1]));
                     }
                 }else{
                     // 정렬표시 삭제
                     if (strHeadText.substr(strHeadText.length - 1) == sConstAscMark || strHeadText.substr(strHeadText.length - 1) == sConstDescMark)
                     {
                         obj.setCellProperty("head", i, "text", strHeadText.substr(0, strHeadText.length - 1));
                     }
                 }
             }
             bindDs.set_rowposition(0);
             bindDs.set_enableevent(true);
         },
         
        /**
         * Grid Head중 check box가 있을 경우, check box 클릭 이벤트 발생시 전체 row에 대한 check/uncheck 설정 함수
         * @param  {object} grid
         * @return N/A
         * @example
         * @memberOf Util
         */
         gridCheckAll : function(obj, e)
         {
             var ffobj = Drps.Util.ffobj;
             var strVal;
             var strBodyExprVal;
             var strChkCol;
             var dsObj;
 
             if(obj.readonly == true) return;
             
             //dsObj = Eco.XComp.lookup(ffobj,obj.binddataset);
             dsObj = obj.getBindDataset();
 
             var strType = obj.getCellProperty("head", e.cell, "displaytype");
 
             if(strType != "checkboxcontrol" || dsObj.rowcount == 0) return;
 
             // Head셋팅
             strVal = obj.getCellProperty("head", e.cell, "text");
             strBodyExprVal = obj.getCellProperty("body", e.col, "expr");
             
             var bodyCellInfo = obj._curFormat._bodycells[e.col];
             var trueValue  = bodyCellInfo.checkboxtruevalue;
             if(typeof trueValue.valueOf=="function")
             {
                 trueValue = trueValue.valueOf();
             }
             var falseValue = bodyCellInfo.checkboxfalsevalue;
             if(typeof falseValue.valueOf=="function")
             {
                 falseValue = falseValue.valueOf();
             }
             if(strBodyExprVal && strBodyExprVal.indexOf("'Y'") > -1)
             {
                 if (strVal == "1")
                 {
                     obj.setCellProperty("head", e.cell, "text", '0');
                     strVal = "N";
                 }else{
                     obj.setCellProperty("head", e.cell, "text", '1');
                     strVal = "Y";
                 }
             }
             else if(trueValue || falseValue)
             {
                 if (strVal == "1")
                 {
                     obj.setCellProperty("head", e.cell, "text", '0');
                     strVal = falseValue;
                 }else{
                     obj.setCellProperty("head", e.cell, "text", '1');
                     strVal = trueValue;
                 }
             }
             else
             {
                 if (strVal == "1")
                 {
                     obj.setCellProperty("head", e.cell, "text", '0');
                     strVal = "0";
                 }else{
                     obj.setCellProperty("head", e.cell, "text", '1');
                     strVal = "1";
                 }
             }
             
             strChkCol = Drps.Util.nvl(obj.getCellProperty("body", e.col, "text"), "");
             strChkCol = strChkCol.split("bind:").join("");
             
             // Body셋팅
             dsObj.set_enableevent(false);
             for (var i = 0; i < dsObj.rowcount; i++)
             {
                 if(obj.getCellPropertyValue(i,e.col,"edittype") != "none")
                 {
                     dsObj.setColumn(i, strChkCol, strVal);
                 }
             }
             
             dsObj.set_enableevent(true);
 
             if(obj.allCheckCallback != null)
             {
                 obj.allCheckCallback(ffobj,strChkCol);
             }
         },
         
