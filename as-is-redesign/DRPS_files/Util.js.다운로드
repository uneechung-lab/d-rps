         * @memberOf Drps.Util
         */ 
         findDatasetRowposKey : function(objDs, objRow)
         {
             let strFind = "";
     
             for(key in objRow)
             {
                 strFind += key + "=='"+objRow[key]+"' &&";
             }
             
             if(strFind)
             {
                 strFind = strFind.substr(0,strFind.length-3);
                 var nCurRow = objDs.findRowExpr(strFind);
                 
                 if (nCurRow < 0) 
                 {
                     nCurRow = 0;
                     objDs.set_rowposition(nCurRow);
                     return objRow;
                 }
                 else
                 {
                     objDs.set_rowposition(nCurRow);
                     return {};
                 }
             }
