                             else
                             {
                                 objGrid.set_autofittype("none");
                             }
                             
                             objGrid.addEventHandler("onsize",this.gridAutofit,ffobj);
                         }
                         else
                         {
                             objGrid.removeEventHandler( "onsize",this.gridAutofit,ffobj);
                         }
