                                 objRow[strColId] = ( objColVl || "" ).toString();
                             } else {
                                 // primitive type
                                 objRow[strColId] = objColVl;
                             }
                         }
                         objArr.push(objRow);
                     }
                     
                 }
                 return JSON.stringify(objArr);
             }
             // 특정한 옵션이 없다면 선택한 행의 모든 데이터를 부모화면으로 전달
             else
             {
                 let objRow = {};
                 let strColId;
                 for(let i = 0; i < objDs.colcount; i++)
                 {
                     strColId = objDs.getColID(i);
                     objColVl = objDs.getColumn(objDs.rowposition, strColId);
                     if ( typeof objColVl == "object" ) {
                         objRow[strColId] = ( objColVl || "" ).toString();
                     } else {
