             if(sColId)
             {
                 let objArr = [];
                 for(let nRow = 0; nRow<objDs.rowcount; nRow++)
                 {
                     let sCheckValue = objDs.getColumn(nRow, sColId);
                     
                     
                     if(sCheckValue == "1" || sCheckValue == "Y")
