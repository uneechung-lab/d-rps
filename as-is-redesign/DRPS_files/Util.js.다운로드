         /**
         * @class Object에 담겨있는 정보를 통해 공통코드 조회하여 각 데이터셋 생성 후 바인드
         * @param {Array} JSON을 담고 있는 배열
         *       - {String}  [component     ] 공통코드를 바인드할 대상이 되는 콤보박스 또는 그리드 (필수)
         *       - {String}  [commCdId      ] 공통코드ID (필수)
         *       - {String}  [columnId      ] component가 그리드인 경우 공통코드를 바인드할 대상이 되는 컬럼 (component가 그리드인 경우 필수)
         *       - {String}  [format        ] 콤보박스 명으로 보여질 부분의 형식 gdsCommCd의 ColumnId를 중괄호에 담는 형식으로 구성 {컬럼ID} default : {commCdNm}
         *       - {String}  [first         ] 만들어진 데이터셋 첫부분에 보여질 명을 설정 내부 코드 값은 ''
         *       - {String}  [last          ] 만들어진 데이터셋 끝부분에 보여질 명을 설정 내부 코드 값은 ''
         * @return
         * @example 
         *       Drps.Util.getComcodeDataset([
                                               { component: this.cmb_acntDivCd_S,        code:"ACNT_DIV_CD" , first:"전체", format:"{commCd}-{commCdNm}" }
                                             , { component: this.cmb_acntLevlCd,         code:"ACNT_LEVL_CD"}
                                             , { component: this.grd_AT1001AcntctCd_01,  code:"ACNT_DIV_CD",  columnId : "acntDivCd" first:"전체", format:"{commCd}-{commCdNm}" }
                                             , { component: this.grd_AT1001AcntctCd_01,  code:"ACNT_LEVL_CD", columnId : "acntLevlCd"}
                                            ]);
         * @memberOf Drps.Util
         */ 
         getComcodeDataset : function(arrTarget)
         {//trace("getComcodeDataset : " + arrTarget);trace("ffobj : " + this.ffobj);
             var ffobj          = this.ffobj;
             var inputDataset   = new Dataset()            ;  // 동적 데이터셋 객체
             var inputDatasetNm = "__inputDatasetCommCd__" ;  // 데이터셋 명칭
             var resultObject   = new Dataset()            ;  // 동적 데이터셋 객체
             var resultObjectNm = "__resultDatasetCommCd__";  // 데이터셋 명칭
 
             // 입력 데이터셋 설정
             this.removeComponent(ffobj, inputDatasetNm);
             inputDataset.set_name(inputDatasetNm);
             inputDataset.addColumn("code", "STRING");
             ffobj.addChild(inputDatasetNm, inputDataset);
             
             // 결과 데이터셋 설정
             Drps.Util.removeComponent(ffobj, resultObjectNm);
             resultObject.set_name (resultObjectNm);
 
             ffobj.addChild(resultObjectNm, resultObject);
             
             // 입력 데이터셋 입력값 연결
             for (var i = 0; i < arrTarget.length; i++)
             {
                 var nRow = inputDataset.addRow();
                 inputDataset.setColumn(nRow, "code", arrTarget[i].code);
             }
             
             // 거래호출
             ffobj.svcTransaction({
                  svcID          : "search"
                , url            : "/comm/code/search.nx"
                , inDataset      : "codes=" + inputDatasetNm
                , outDataset     : resultObjectNm + "=dsCommCdList"
                , callbackFunc   : ""
                , async          : false // 싱크처리(동기)
             });
 
             var dataSets = {};
             for(var i = 0; i < arrTarget.length; i++)
             {
                 var tmpObject       = {};
                 tmpObject.component = arrTarget[i].component               ;
                 tmpObject.code      = arrTarget[i].code                    ;
                 tmpObject.columnId  = arrTarget[i].columnId || ""          ;
                 tmpObject.format    = arrTarget[i].format   || "{commCdNm}";
                 
                 // 데이터셋 동적 생성 > "__daComponentName_ColumnId__"
                 tmpComnentDataset   = new Dataset();
                 tmpComnentDatasetNm = "__ds" + tmpObject.component.name+"_"+tmpObject.columnId + "__";
                 var seq = 0;
                 while(dataSets[tmpComnentDatasetNm])
                 {
                     tmpComnentDatasetNm = "__ds" + tmpObject.component.name+"_"+tmpObject.columnId + "_" + (seq++) + "__";
                 }
                 Drps.Util.removeComponent(ffobj, tmpComnentDatasetNm);
                 tmpComnentDataset.set_name(tmpComnentDatasetNm);
                 ffobj.addChild(tmpComnentDatasetNm, tmpComnentDataset);
                 dataSets[tmpComnentDatasetNm] = tmpComnentDataset;
                 
                 resultObject.filter("commCdId == '"+arrTarget[i].code+"'");
                 tmpComnentDataset.copyData(resultObject, true);
                 tmpComnentDataset.addColumn("formatCdNm", "STRING");
                 
 
                 for(var rowIdx = 0; rowIdx < tmpComnentDataset.rowcount; rowIdx++)
                 {
                     tmpComnentDataset.setColumn(rowIdx,"formatCdNm", tmpObject.format);
                     for(var j = 0; j < tmpComnentDataset.colcount; j++)
                     {                        
                         var colId         = tmpComnentDataset.getColID(j);
                         var colIdExp      = new RegExp("{"+colId+"}","gi");
                         var strFormatCdNm = tmpComnentDataset.getColumn(rowIdx, "formatCdNm");                        
                         var strColValue   = tmpComnentDataset.getColumn(rowIdx, colId);
                         tmpComnentDataset.setColumn(rowIdx, "formatCdNm", strFormatCdNm.replace(colIdExp, strColValue));
                     }
                 }
                 
                 tmpComnentDataset.set_filterstr("useYn=='Y'");
 
                 //맨앞 또는 맨뒤에 보조행 추가
                 if(arrTarget[i].first != undefined)
                 {
                     var nRow = tmpComnentDataset.insertRow(0);
                     tmpComnentDataset.setColumn(nRow, "commCd", "");
                     tmpComnentDataset.setColumn(nRow, "formatCdNm", arrTarget[i].first);
                 }
                 else if(arrTarget[i].last != undefined)
                 {
                     var nRow = tmpComnentDataset.addRow();
                     tmpComnentDataset.setColumn(nRow, "commCd", "");
                     tmpComnentDataset.setColumn(nRow, "formatCdNm", arrTarget[i].last);
                 }
                 
                 // 콤보박스 또는 라디오버튼 일때 바인드
                 if(this.typeOf(tmpObject.component) == "Combo" || this.typeOf(tmpObject.component) == "Radio")
                 {
                     tmpObject.component.set_innerdataset(tmpComnentDatasetNm);
                     tmpObject.component.set_codecolumn("commCd"    );
                     tmpObject.component.set_datacolumn("formatCdNm");
                 }
                 // 그리드 일때 바인드
                 else if(this.typeOf(tmpObject.component) == "Grid")
                 {
                     var curFormatId = tmpObject.component.formatid;
                     for(var formatKey in tmpObject.component._formats)
                     {
                         tmpObject.component.setFormat(formatKey);
                         var colIdx = tmpObject.component.getBindCellIndex("Body", tmpObject.columnId);
                         
                         tmpObject.component.setCellProperty("Body", colIdx, "combodataset", tmpComnentDatasetNm);
                         tmpObject.component.setCellProperty("Body", colIdx, "combocodecol", "commCd"           );
                         tmpObject.component.setCellProperty("Body", colIdx, "combodatacol", "formatCdNm"       );
                     }
                     tmpObject.component.setFormat(curFormatId);
                 }
             }
             
             // 결과 데이터셋 삭제
             resultObject = null;
         },
         
