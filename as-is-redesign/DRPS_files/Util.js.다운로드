         /**
          * @class   대상에서 오브젝트 반환
          * @param {Object} p - 오브젝트를 찾을 대상
          * @param {String} name - 오브젝트네임
          * @return {Object} 오브젝트
          * @example
          * Drps.Util.lookup(this, "dsList"); 
          * @memberOf Drps.Util
          */
         lookup : function(p, name)
         {
             var o;
             while (p)
             {       
                 o = p.components;
                 if ( o && o[name] ) return o[name];
                 
                 o = p.objects;
                 if ( o && o[name] ) return o[name];
                 
                 p = p.parent;
             }
             return null;
         },
 
         /**
          * @class Grid에서 expression으로  표현할때 decode 문처럼 사용할 수 있는 기능
          * @param N/A 
          * @return {String} varRtnValue - 반환된 문자열
          * @example
          * Drps.Util.decode();   
          * @memberOf Drps.Util
          */
         decode : function ()
         {
             var varRtnValue = null;
 
             var arrArgument = this.decode.arguments;
             var varValue = arrArgument[0];
             var bIsDefault = false;
             var nCount = 0;
 
             if ((arrArgument.length % 2) == 0) 
             {
                 nCount = arrArgument.length - 1;
                 bIsDefault = true;
             }
             else 
             {
                 nCount = arrArgument.length;
                 bIsDefault = false;
             }
 
             for (var i = 1; i < nCount; i += 2) 
             {
                 if (varValue == arrArgument[i]) 
                 {
                     varRtnValue = arrArgument[i + 1];
                     i = nCount;
                 }
             }
 
             if (varRtnValue == null && bIsDefault) 
             {
                 varRtnValue = arrArgument[arrArgument.length - 1];
             }
 
             return varRtnValue;
         },
         
         /**
         * @class 공통 유효성 검사 (null check)
         * @param {object} objDiv or objGrid         검사할 div 또는 그리드
         * @param {object} 매치할 user_valid속성의 값
         * @param {var} 이후 확장속성 기본은 null check 해당 값에 따라 여러 체크 수행을 할 예정
         * @return boolean   true면 이상없음 false면 에러 메시지
         * @example      if(Drps.Util.valid("IQRY"))
                                         {
                                                 this.fn_estimate();
                                         }
         * @memberOf Drps.Util
         */
         valid : function(sOption, sType)
         {
             var ffobj = this.ffobj;
             
             var com_bool = true;
             var objJson;
             var objGrid;
             
             var objComps = Drps.Core.getAll(ffobj).components;
             
             if (sType == null)
             {
                 var leng = objComps.length;
                 for(var i=0;i<leng;i++)
                 {
                     if(this.typeOf(objComps[i]) == "Grid")
                     {
                         if(objComps[i].validation != null)
                         {
                             objGrid = objComps[i];
                             var objds = objGrid.getBindDataset();
                             objJson = objGrid.validation;
 
                             var colidx; 
                             var dsleng;
                             for(var j=0;j<objJson.length;j++)
                             {
                                 if(!com_bool){ break;}
 
                                 if(objJson[j].group == sOption)
                                 {
                                     colidx = objGrid.getBindCellIndex("Body",objJson[j].name);
                                     dsleng = objds.getRowCount();
 
                                     for(var k=0;k<dsleng;k++)
                                     {   
                                         // 변경된 자료에 대해서만 유효성 검사
                                         if(objds.getRowType(k) == Dataset.ROWTYPE_INSERT || objds.getRowType(k) == Dataset.ROWTYPE_UPDATE)
                                         {
                                             if(objds.getColumn(k,objJson[j].name) == null || objds.getColumn(k,objJson[j].name) === "")
                                             {
                                                 Drps.Util.alertBox(objJson[j].msg, function() {
													objds.set_rowposition(k);
													 objGrid.setCellPos(colidx, k);
													 objGrid.showEditor();
													 
													 // 바인딩된 폼이 있다면 해당 컴포넌트에 포커스
													 for(let nItem=0;nItem<ffobj.binds.length;nItem++)
													 {
														 if(ffobj.binds[nItem].datasetid == objds.name && ffobj.binds[nItem].columnid == objJson[j].name)
														 {
															 ffobj.binds[nItem]._comp.setFocus();
															 break;
														 }
													 }
												 });
                                                 com_bool = false;
                                                 return com_bool;
                                             }
                                         }
                                     }
                                 }
                             }
                         }
                     }
                     else
                     {
                         if(objComps[i].validation != null)
                         {
                             objJson = objComps[i].validation;
                             if(objJson["group"] == sOption)
                             {
                                 for(let bind=0;bind<ffobj.binds.length;bind++)
                                 {
                                     if(ffobj.binds[bind]._comp == objComps[i])
                                     {
                                         ffobj.binds[bind]._dataset.set_enableevent(false);
                                         objComps[i].set_value(ffobj.binds[bind]._dataset.getColumn(ffobj.binds[bind]._dataset.rowposition,ffobj.binds[bind].columnid));
                                         ffobj.binds[bind]._dataset.set_enableevent(true);
                                     }
                                 }
                                 
                                 if(objComps[i].value == null || objComps[i].value === "")
                                 {
                                     Drps.Util.alertBox(objJson["msg"],function(){
										objComps[i].setFocus();
									 });
                                     com_bool = false;
                                     return com_bool;
                                 }
                             }
                         }
                     }
                 }
             }
             
             return com_bool;
         },
 
