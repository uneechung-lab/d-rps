         /**
          * 23.12.06 LDW
          * @class  사업자 및 법인번호 마스킹처리
          * @param  {String} bizNo - 사업자 또는 법인번호
          * @return {String} bizNoFormat - 마스킹처리된 사업자 또는 법인번호
          * @example
          * Drps.Util.GetFormatBizNo("1234567890123"); => (13자리) 123456-7890123
          * Drps.Util.GetFormatBizNo("1234567890");    => (10자리) 123-45-67890
          * @memberOf Drps.Util
          */
         GetFormatBizNo : function(bizNo)
         {
            var bizNoFormat = nexacro.trim(bizNo);
            
            if(bizNoFormat.length == 13) {
                bizNoFormat = bizNoFormat.substring(0, 6) + "-" + bizNoFormat.substring(6, 13);
            } else if(bizNoFormat.length == 10) {
                bizNoFormat = bizNoFormat.substring(0, 3) + "-" + bizNoFormat.substring(3, 5) + "-" + bizNoFormat.substring(5, 10);
            }
            
            return bizNoFormat;
         },
		 
         /**
          * @class String -> JSON 변환
          * @param {String} strJson
          * @return objJson
          */
         strToJson : function(strJson)
         {
			if(typeof strJson == "boolean"){
				return strJson;
			}
			let objJson = null;
			if(strJson != undefined && strJson != ""){
				try {
					objJson = JSON.parse(strJson);
				} catch(e) {
					objJson = null;
				}
			}
			return objJson;
         },
         /**
          * @class 전화번호 유효성 체크
          * @param {String} sValue
          * @return Boolean
          */
		isPhone : function(sValue) 
        {
            if (Drps.Util.isNull(sValue)) return false;

            let regExp = /^(01[016789]|02|0[3-9]{1}[0-9]{1}|050[2-9])([0-9]{3,4})([0-9]{4})$/;
            let tempValue = sValue.toString().replace(/[^0-9]/g, "");

            return regExp.test(tempValue);
        }
      });
