         /**
          * 프로그래밍으로 dataset을 만든단다.
          * 폼에 dsName이 있는 경우 해당 dataset을 그대로 사용한다.
          * 
          * 단건 Drps.Util.createDataset(this, "dsTemp",  { commCdId: "", commCd : ""} );
          * 다건 Drps.Util.createDataset(this, "dsTemp", [{ commCdId: "", commCd : ""}] );
          *      Drps.Util.createDataset(this, "dsTemp");
          * this.svcTransaction({
          *       svcID       : "svcID"
          *     , url         : "...."
          *     , inDataset   : "dsBasSmple=dsTemp"
          *     , outDataset  : "dsTemp=dsBasSmpleList"
          *     , callbackFunc: "fnCallback"
          *   });
          *
          * this.fnCallback = function(svcID, errorCode, errorMsg) {
          *    trace(dsTemp.saveXML());
          * }
          */
         createDataset : function(objForm, dsName, param) {
             param = param || {};
             
             var dsTemp = Drps.Util.lookup(objForm, dsName);
             if ( dsTemp == null ) {
                 dsTemp      = new Dataset;
                 dsTemp.name = dsName;
                 objForm.addChild(dsName, dsTemp);
             }
             
             dsTemp.clear();
             
             if ( ! Array.isArray(param) ) {
                 param = [param];
             }
             
             var arrColumn = Object.keys(param[0]);
             for (var i = 0; i < arrColumn.length; i++) {
                 dsTemp.addColumn(arrColumn[i], "STRING");
             }
             
             for (var i = 0; i < param.length; i++ ) {
                 var row = dsTemp.addRow();
                 var arrValue = Object.values(param[i]);
                 for (var k = 0; k < arrColumn.length; k++) {
                     dsTemp.setColumn(row, arrColumn[k], arrValue[k]);
                 }
             }
             
             return dsTemp;
         },
         /**
          * 팝업 거래를 호출 하여 값을 리턴한다. 2건 이상 리턴시 팝업창을 호출한다.
          * 
          */
         popupTransaction : function(objForm, options) {
             var tmpInDataset  = "__intmp__" + options.inDataset ;
             var tmpOutDataset = "__outtmp__" + options.outDataset;
             var inDs  = Drps.Util.createDataset(objForm, tmpInDataset , options.parameter );
             var outDs = Drps.Util.createDataset(objForm, tmpOutDataset                    );
             objForm.svcTransaction({
                 url         : options.url                                   // 거래 URL
               , inDataset   : options.inDataset + "=" + tmpInDataset        // 입력데이터셋 - "서버=화면 서버1=화면1...N"
               , outDataset  : tmpOutDataset     + "=" + options.outDataset  // 출력데이터셋 - "화면=서버 화면1=서버1...N"
               , pageSize    : 2                                             // 페이징처리
               , async       : false
             });
             
             let rtnObj = {};
             if ( outDs.getRowCount() == 1 ) {
                 let strColId;
                 for ( let i = 0; i < outDs.colcount; i++ )
                 {
                     strColId = outDs.getColID(i);
                     objColVl = outDs.getColumn(outDs.rowposition, strColId);
                     if ( typeof objColVl == "object" ) {
                         rtnObj[strColId] = ( objColVl || "" ).toString();
                     } else {
                         // primitive type
                         rtnObj[strColId] = objColVl;
                     }
                 }
             } else {
                 rtnObj = Drps.Util.openPopup(options.popupUrl, options.popupUrl, options.parameter);
             }
             return rtnObj || {} ;
         }
