         * @param {Boolean     } [enable ] : 활성화 여부(true:활성화,false:비활성화)
         * @param {String      } [filters] : 포함 대상 component type(delimiter:comma)(ALL:전체)(default:ALL)
         * @return N/A
         * @example
         * Drps.Util.setChildEnable(this,false,"Edit,MaskEdit,Calendar");
         * Drps.Util.setChildEnable(this,false,"ALL");
         */
        setChildEnable : function(formObj, enable, filters)
        {
            if(formObj==null)
            {
                Drps.Core.showError("undefined parameter : formObj - " + formObj);
                return;
            }
            if(!(formObj instanceof nexacro.Form))
            {
                Drps.Core.showError("illegal parameter : formObj - " + formObj);
                return;
            }
            if(typeof enable != "boolean")
            {
                Drps.Core.showError("illegal parameter : enable - " + typeof enable);
                return;
            }
            if(filters==null)
            {
                filters = "ALL";
            }
            if(typeof filters!="string")
            {
                Drps.Core.showError("illegal parameter : filters - " + typeof filters);
                return;
            }
            let filterArr = filters.split(",");
            let objComps = Drps.Core.getAll(formObj).components;
            compLoop : for(let i in objComps)
            {
                let objComp = objComps[i];
                if(typeof objComp.set_enable=="function")
                {
                    if(filters==="ALL")
                    {
                        objComp.set_enable(enable);
                    }
                    else
                    {
                        filterLoop : for(let x in filterArr)
                        {
                            let filter     = filterArr[x];
                            let filterType = nexacro[filter];
                            if(filterType==null){continue filterLoop;}
                            if(objComp instanceof filterType)
                            {
                                objComp.set_enable(enable);
                                continue compLoop;
                            }
                        }
                    }
                }
            }
             
        },
