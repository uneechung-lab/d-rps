/************************************************************************
 * Form close 공통
 ************************************************************************/
if(!Drps.Prototype.form._formCloseFunc)
{
    Drps.Prototype.form._formCloseFunc = Drps.Prototype.form.close;
}
Drps.Prototype.form.close = function(arg)
{
    if(Drps.Core.formCloseCheck(this)===false){return false;}
    let formId  = Drps.Core.getIdOfWorkForm(this);
    if(formId && typeof nexacro.getApplication()._closeProcess=="undefined")
    {
        return nexacro.getApplication().gfnClose(formId);
    }
    else
    {
        return this._formCloseFunc(arg);
    }
};

/************************************************************************
 * Form reload 공통
 ************************************************************************/
if(!Drps.Prototype.form._formReloadFunc)
{
    Drps.Prototype.form._formReloadFunc = Drps.Prototype.form.reload;
}
Drps.Prototype.form.reload = function()
{
    if(typeof this._attKeyObj=="object")
    {
        for(let key in this)
        {
            if(!this._attKeyObj[key])
            {
                delete this[key];
            }
        }
    }

    this._hotkey_list = [];
    delete this._userInit;
    this._formReloadFunc();    
};

/************************************************************************
 * form onload intercept
 ************************************************************************/
if(!Drps.Prototype.form._formLoadEvent)
{
    Drps.Prototype.form._formLoadEvent = Drps.Prototype.form.on_fire_onload;
}
Drps.Prototype.form.on_fire_onload = function(obj,url)
{
    try
    {    
        this._attKeyObj = {};
        for(let key in this)
        {
            this._attKeyObj[key] = true;
        }
        let frame       = this.getOwnerFrame();
        let workFormId  = Drps.Core.getIdOfWorkForm (this);
        let quickViewId = Drps.Core.getIdOfQuickView(this);
        let popupId     = Drps.Core.getIdOfPopupForm(this);
        if(workFormId && !this._userInit)
        {
            this._pageId    = workFormId;
            frame._pageId   = workFormId;
            this._openerId  = workFormId;
            frame._openerId = workFormId;
            if(frame._params)
            {
                if(frame._params._openerId)
                {
                    this._openerId  = frame._params._openerId;
                    frame._openerId = frame._params._openerId;
                    delete frame._params._openerId;
                }
                this.paramContents = frame._params;
            }
            else if(this.paramContents)
            {
                delete this.paramContents;
            }
            Drps.Core.formInit(this);
        }
        else if(quickViewId && !this._userInit)
        {
            if(!nexacro.getApplication()._exitFunc)
            {
                let formObj = this;
                nexacro.getApplication()._exitFunc = nexacro.getApplication().exit;
                nexacro.getApplication().exit = function()
                {
                    if(Drps.Core.formCloseCheck(formObj)===false){
                        return false;
                    }
                    nexacro.getApplication().__absltClose = true;
                    nexacro.getApplication()._exitFunc();
                };
            }
            this._pageId  = quickViewId;
            frame._pageId = quickViewId;
            Drps.Core.formInit(this);
        }
        else if(popupId && !this._userInit)
        {
            this._pageId    = popupId;
            frame._pageId   = popupId;
            this._openerId  = workFormId;
            frame._openerId = workFormId;
            if(frame._params)
            {
                if(frame._params._openerId)
                {
                    this._openerId  = frame._params._openerId;
                    frame._openerId = frame._params._openerId;
                    delete frame._params._openerId;
                }
                this.paramContents = frame._params;
            }
            Drps.Core.formInit(this);
        }
    }
    catch(err)
    {
//         let errorTrace = [];
//         errorTrace.push("form : " + this.name);
//         errorTrace.push(err.message);
//         for(let i in err.stack)
//         {
//             errorTrace.push(err.stack[i]);
//         }
//         if(typeof this.svcTransaction=="function")
//         {
//             this.svcTransaction(
//                                 {
//                                  svcID    : "empty"
//                                 ,url      : "/XX/errtrace.nx"
//                                 ,argument : Drps.Core.setParam("errorTrace",errorTrace.join("\n"))
//                                 }
//                                );
//         }
        throw err;
    }
    return this._formLoadEvent(obj,url);
};

