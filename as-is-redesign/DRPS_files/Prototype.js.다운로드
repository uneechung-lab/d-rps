/*******************************************************************************************************************************************************
 * 서버통신 메인
 * @param {Object} [options] - 호출옵션
 *                           - {String}                       [svcID         ] 서비스 ID       (필수)
 *                           - {String}                       [url           ] 서비스 호출 URL (필수)
 *                           - {String}                       [inDataset     ] input  Dataset  list("입력ID=DataSet ID" 형식으로 설정하며 빈칸으로 구분)
 *                           - {String}                       [outDataset    ] output Dataset  list("DataSet ID=출력ID" 형식으로 설정하며 빈칸으로 구분)
 *                           - {String}                       [argument      ] input  argument list("입력ID=입력값" 형식으로 설정하며 빈칸으로 구분)
 *                           - {String}                       [callbackFunc  ] 콜백 함수명
 *                           - {Boolean}                      [async         ] 비동기여부       (true:비동기화, false:동기화  )
 *                           - {Number}                       [dataType      ] 전송 데이터 타입 (0:XML,   1:Binary,   2:SSV   )
 *                           - {Boolean}                      [compress      ] 데이터 압축 여부 (true:압축    , false:압축안함)
 *                           - {Boolean}                      [isToastr      ] toastr 메세지 표시 여부 (default:true)
 * @return N/A
 * @example
 * this.svcTransaction(
 *               {
 *                svcID          : "save"
 *               ,url            : "transactionSaveTest.do"
 *               ,inDataset      : "dsList=dsList:U"
 *               ,outDataset     : "dsList=dsList"
 *               ,argument       : "test=a123"
 *               ,callbackFunc   : "fnCallback"
 *               ,async          : true
 *               ,dataType       : 0
 *               ,compress       : false
 *               ,isToastr       : true
 *               }
 *              );
 *******************************************************************************************************************************************************/
Drps.Prototype.form.svcTransaction = function( options )
{
    let dsHeader  = nexacro.getApplication().gdsBaseHeader;
    let svcUrl    = nexacro.getEnvironment().services.svcurl;

    options              = options             ||{};
    options.url          = options.url         ||"";
    options.inDataset    = options.inDataset   ||"";
    options.outDataset   = options.outDataset  ||"";
    options.argument     = options.argument    ||"";
    options.callbackFunc = options.callbackFunc||"";
    options.async        = options.async;
    options.dataType     = options.dataType    ||0;
    options.compress     = options.compress    ||false;
    options.isToastr     = options.isToastr;
    if(options.isToastr!==false)
    {
        options.isToastr = true;
    }

    let svcObj      = {strSvcID:options.svcID,strCallbackFunc:options.callbackFunc};
    if(options._showWaitCursor===false)
    {
        svcObj.showWaitCursor = false;
    }
    let tranURL     = svcUrl.url + options.url;
    let outDatasets = options.outDataset.split(" ");
    
    let outTargetDs = "";
    let outTmpDs    = "";
    
    /**
     * dsHeader 세팅
     */
    let dsHeaderTmp = new Dataset;
    dsHeaderTmp.loadXML(dsHeader.saveXML());
    dsHeaderTmp.clearData();
    dsHeaderTmp.addRow();
    let headerSeq    = 0;
    dsHeaderTmp.name = "__ds_header_"+headerSeq+"__";
    while(this[dsHeaderTmp.name])
    {
        dsHeaderTmp.name = "__ds_header_"+(++headerSeq)+"__";
    }
    dsHeaderTmp.useclientlayout = false;
    this.addChild(dsHeaderTmp.name,dsHeaderTmp);
    
    let strInDatasets = "drpsheader="+dsHeaderTmp.id+" "+options.inDataset;
  
    let outDataMaps = {};
    let strOutDatasetArr = [dsHeaderTmp.id+"=drpsheader"];
    outDataMaps.headerDs = {
                            outDataKey  :dsHeaderTmp.id
                           ,outDataValue:"gdsBaseHeader"
                           ,outDataOrg  :dsHeaderTmp.id
                           };
	
	//화면별 권한체크 화면ID가 존재하지 않는다면 팝업ID
	let screenId = this.getOwnerFrame()._scrinId;
	screenId = (screenId == undefined) ? this.getOwnerFrame().id : screenId;

    dsHeaderTmp.setColumn(0,"screenId", screenId);    

    outDataMaps.arrOuts = [];
    for(var i in outDatasets){
        if(!outDatasets[i]){continue;}
        let outDataset   = outDatasets[i].split("=")||[];
        let outDataKey   = outDataset[0]||"";
        let outDataValue = outDataset[1]||"";
        let outDataOrg   = outDataset[0]||"";
        if(!outDataKey || !outDataValue){continue;}
        if(outTmpDs && outDataKey==outTargetDs.id){
            outDataKey = outTmpDs.id;
            outDataMaps.targetDs = {
                                    outDataKey  :outDataKey
                                   ,outDataValue:outDataValue
                                   ,outDataOrg  :outDataOrg
                                   };
        }
        let outDsInfo = {
                         outDataKey  :outDataOrg
                        ,outDataValue:outDataValue
                        };
        outDataMaps.arrOuts.push(outDsInfo);
        strOutDatasetArr.push(outDataKey+"="+outDataValue);
    }
    
    let strOutDatasets = strOutDatasetArr.join(" ");
    
    svcObj.outDataMaps = outDataMaps;
    
    // toss alert push 여부
    let pattern = /\/(save|insert|update|delete)/g;
    if(pattern.test(tranURL) && options.isToastr)
    {
        svcObj.isToastr = true;
    }
    
    let httptimeout = nexacro.getEnvironment().httptimeout;
    if(typeof options._httptimeout=="number")
    {
        nexacro.getEnvironment().set_httptimeout(options._httptimeout);
    }
    nexacro.getApplication().gfnAccsTmUpd();
	
	
	
    this.transaction(svcObj
                    ,tranURL
                    ,strInDatasets
                    ,strOutDatasets
                    ,options.argument
                    ,"_tranCallback"
                    ,options.async
                    ,options.dataType
                    ,options.compress);
    if(typeof options._httptimeout=="number")
    {
        nexacro.getEnvironment().set_httptimeout(httptimeout);
    }
};

/*******************************************************************************************************************
 * @서버통신 공통 Callback
 * 이 함수가 먼저 수행되고 사용자지정 Callback함수가 수행된다.
 * @param {Object} [svcObj   ] - 서비스 Object
 *                               - {String}         [strSvcID       ] : 서비스ID
 *                               - {String}         [strCallbackFunc] : 사용자지정 Callback함수명
 *                               - {Boolean}        [isToastr       ] : toastr alert 여부(default:false)
 *                               - {nexacro.Grid}   [targetGrid     ] : 조회대상 Grid
 *                               - {nexacro.Button} [nextButton     ] : 다음조회 Button
 *                               - {Object}         [outDataMaps    ] : output Dataset 정보 Map
 *                                 - {Object  } [headerDs] : output header 정보 (format : gdsBaseHeader)
 *                                   - {String} [outDataKey  ] : output header Dataset ID
 *                                   - {String} [outDataValue] : output header 출력 ID (gdsBaseHeader)
 *                                   - {String} [outDataOrg  ] : output header 원천 Dataset ID (outDataKey와 동일)
 *                                 - {Object  } [targetDs] : output body   정보 (연속조회시 생성)
 *                                   - {String} [outDataKey  ] : output Dataset ID
 *                                   - {String} [outDataValue] : output 출력 ID
 *                                   - {String} [outDataOrg  ] : output 원천 Dataset ID
 *                                 - {Object[]} [arrOuts ] : output Dataset Array
 *                                   - {String} [outDataKey  ] : output Dataset ID
 *                                   - {String} [outDataValue] : output 출력 ID
 * @param {Number} [errorCode] - 에러코드(정상 0, 시스템에러 음수값, 업무에러 양수값)
 * @param {String} [errorMsg ] - 에러메시지
 * @return N/A
 *******************************************************************************************************************/
Drps.Prototype.form._tranCallback = function(svcObj,errorCode,errorMsg)
{
    let strSvcID        = svcObj.strSvcID;
    let strCallbackFunc = svcObj.strCallbackFunc;
    let outDataMaps     = svcObj.outDataMaps;
   // let targetGrid      = svcObj.targetGrid;
    //let nextButton      = svcObj.nextButton     ||{};
    let dsHeaderInfo    = outDataMaps.headerDs   ||{};
    let dsHeaderKey     = dsHeaderInfo.outDataKey||"";
    let dsHeader        = this[dsHeaderKey]      ||"";
    let nextPageYn      = "N";
    let procCntn        = "";
    
    let isToastr        = svcObj.isToastr;
    if(isToastr===true)
    {
        isToastr = true;
    }
    else
    {
        isToastr = false;
    }
 
    if(dsHeader instanceof nexacro.Dataset)
    {
        nextPageYn = dsHeader.getColumn(0,"isContinue");
        procCntn   = dsHeader.getColumn(0,"procCntn");
        let removedHeader = this.removeChild(dsHeaderKey);
        if(removedHeader)
        {
            removedHeader.destroy();
        }
    }
    
    if(procCntn)
    {
        Drps.Core.setStatus(procCntn);
        if(isToastr)
        {
			//FIXME
            //Drps.Util.toastrAlert(procCntn);
        }
    }
    
    if(errorCode!==0)
    {
        errorMsg = errorMsg||"";
        if(errorCode===-1 && errorMsg==="FAILED")
        {
            errorMsg = "[시스템 장애] 시스템 관리자에게 문의하세요. 1111-2222";
        }
        if(svcObj._returncode===10400)
        {
            errorMsg = "사용자 요청으로 통신이 중단되었습니다.\n요청하신 거래는 서버에서 계속 진행됩니다.";
            let msgSplitter = nexacro.getApplication().gvMsgSplitter;
            let strErrMsg   = "[INFO] - "+errorMsg.split(msgSplitter)[0];
            Drps.Core.setStatus(strErrMsg);
            Drps.Util.alertBox(errorMsg,null,null,"INFO");
        }
        else
        {
            let msgSplitter = nexacro.getApplication().gvMsgSplitter;
            let strErrMsg   = "[ERROR] - "+errorMsg.split(msgSplitter)[0];
            Drps.Core.setStatus(strErrMsg);
            Drps.Util.alertBox(errorMsg,null,null,"ERR");
        }
        
        if(errorCode===-10)
        {
            nexacro.getApplication().__absltClose = true;
            nexacro.getApplication().gfnCloseAll();
            delete nexacro.getApplication().__absltClose;
            nexacro.getApplication().gfnAppClear();
        }
        else if(this[svcObj.strCallbackFunc])
        {
            nexacro.getApplication().gfnAccsTmUpd();
            try{
                this[svcObj.strCallbackFunc](svcObj.strSvcID,errorCode,errorMsg);
            }catch(err){
				trace(err.message);
            }
        }
        return;
    }
    nexacro.getApplication().gfnAccsTmUpd();
   
    if(outDataMaps){
        let targetDs = outDataMaps.targetDs;
        if(targetDs){
            let outDataKey = targetDs.outDataKey;
            let outDataOrg = targetDs.outDataOrg;
            if(outDataKey && outDataOrg)
            {
                this[outDataOrg].appendData(this[outDataKey]);
            }
            let removedTmp = this.removeChild(outDataKey);
            if(removedTmp)
            {
                removedTmp.destroy();
            }
        }
        if(outDataMaps.arrOuts && (outDataMaps.arrOuts instanceof Array))
        {
            let allObj   = Drps.Core.getAll(this);
            let allComp  = allObj.components;
            let allGrids = [];
            for(let i=0;i<allComp.length;i++)
            {
                let component = allComp[i];
                if(component && (component instanceof nexacro.Grid))
                {
                    allGrids.push(component);
                }
            }
            for(let i=0;i<outDataMaps.arrOuts.length;i++)
            {
                let outDs = outDataMaps.arrOuts[i];
                for(let x=0;x<allGrids.length;x++)
                {
                    let gridObj     = allGrids[x];
                    let bindDataset = gridObj.binddataset;
                    if(outDs.outDataKey==bindDataset)
                    {
						if(gridObj.nodatatext == undefined || gridObj.nodatatext == "") {
							gridObj.set_nodatatext("조회 내역이 없습니다.");
						}
                    }
                }
            }
        }
    }
    
    if(this[svcObj.strCallbackFunc]){
        try{
            this[svcObj.strCallbackFunc](svcObj.strSvcID,errorCode,errorMsg, (nextPageYn=="Y"?true:false));
        }catch(err){
			trace(err.message);
        }
    }
};

